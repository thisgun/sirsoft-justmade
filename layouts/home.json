{
    "version": "1.0.0",
    "layout_name": "home",
    "permissions": [],
    "extends": "_user_base",
    "meta": {
        "seo": {
            "enabled": true,
            "data_sources": ["stats", "notice_posts", "popular_posts", "home_boards", "new_products"],
            "priority": 1.0,
            "changefreq": "daily",
            "og": {
                "type": "website"
            },
            "structured_data": {
                "@type": "WebSite",
                "name": "{{_global.site_name ?? ''}}",
                "url": "{{_global.site_url ?? ''}}"
            }
        }
    },
    "data_sources": [
        {
            "id": "stats",
            "type": "api",
            "endpoint": "/api/modules/sirsoft-board/boards/stats",
            "method": "GET",
            "auto_fetch": true,
            "loading_strategy": "progressive",
            "fallback": {
                "data": {
                    "users": 0,
                    "posts": 0,
                    "comments": 0,
                    "boards": 0
                }
            }
        },
        {
            "id": "notice_posts",
            "type": "api",
            "endpoint": "/api/modules/sirsoft-board/boards/notice/posts?per_page=3",
            "method": "GET",
            "auto_fetch": true,
            "loading_strategy": "progressive",
            "fallback": {
                "data": []
            }
        },
        {
            "id": "popular_posts",
            "type": "api",
            "endpoint": "/api/modules/sirsoft-board/boards/popular?period=week&limit=10",
            "method": "GET",
            "auto_fetch": true,
            "loading_strategy": "progressive",
            "fallback": {
                "data": []
            }
        },
        {
            "id": "home_boards",
            "type": "api",
            "endpoint": "/api/modules/sirsoft-board/boards?limit=3",
            "method": "GET",
            "auto_fetch": true,
            "loading_strategy": "progressive",
            "fallback": {
                "data": []
            }
        },
        {
            "id": "gallery_posts",
            "type": "api",
            "endpoint": "/api/modules/sirsoft-board/boards/gallery/posts?per_page=4",
            "method": "GET",
            "auto_fetch": true,
            "loading_strategy": "progressive",
            "fallback": {
                "data": []
            }
        },
        {
            "id": "new_products",
            "type": "api",
            "endpoint": "/api/modules/sirsoft-ecommerce/products/new?limit=4",
            "method": "GET",
            "auto_fetch": true,
            "loading_strategy": "progressive",
            "fallback": {
                "data": []
            }
        }
    ],
    "slots": {
        "content": [
            {
                "comment": "=== 0: 히어로 섹션 (풀 와이드, Container 밖) ===",
                "type": "layout",
                "name": "Container",
                "props": { "className": "px-4 pt-6 pb-0" },
                "responsive": {
                    "tablet": { "props": { "className": "px-6 pt-6 pb-0" } },
                    "desktop": { "props": { "className": "pt-6 pb-0" } }
                },
                "children": [
                    { "partial": "partials/home/_hero_section.json" }
                ]
            },
            {
                "comment": "=== 1: 커뮤니티 섹션 (인기글 + 요약, Surface Elevated 배경) ===",
                "type": "basic",
                "name": "Div",
                "props": { "className": "bg-base-200/50 rounded-2xl py-8 lg:py-10" },
                "children": [
                    {
                        "type": "layout",
                        "name": "Container",
                        "props": { "className": "px-4" },
                        "responsive": {
                            "tablet": { "props": { "className": "px-6" } }
                        },
                        "children": [
                            {
                                "comment": "섹션 헤더 + 공지 로테이션",
                                "type": "basic",
                                "name": "Div",
                                "props": { "className": "mb-10" },
                                "children": [
                                    { "type": "basic", "name": "Span", "props": { "className": "text-editorial-eyebrow block mb-2 text-base-content" }, "text": "Community" },
                                    { "type": "basic", "name": "H2", "props": { "className": "text-2xl lg:text-3xl font-black tracking-tight text-base-content" }, "text": "$t:footer.community" }
                                ]
                            },
                            {
                                        "comment": "=== 공지사항 로테이션 (3개, 한 줄씩 순환) ===",
                                        "type": "basic",
                                        "name": "Div",
                                        "if": "{{notice_posts.data && notice_posts.data.data && notice_posts.data.data.length > 0}}",
                                        "props": { "className": "mb-10 flex items-center gap-3 bg-base-100 rounded-xl px-5 py-2.5 shadow-sm" },
                                        "children": [
                                            {
                                                "comment": "티커 영역",
                                                "type": "basic",
                                                "name": "Div",
                                                "props": { "className": "flex-1 overflow-hidden h-10 relative notice-ticker" },
                                                "children": [
                                                    {
                                                        "type": "basic",
                                                        "name": "Div",
                                                        "props": { "className": "notice-ticker-track absolute inset-x-0" },
                                                        "children": [
                                                            {
                                                                "type": "basic",
                                                                "name": "Div",
                                                                "iteration": { "source": "{{notice_posts.data.data ?? []}}", "item_var": "notice" },
                                                                "children": [
                                                                    {
                                                                        "type": "basic",
                                                                        "name": "Button",
                                                                        "props": { "className": "flex items-center justify-start gap-3 w-full h-10 cursor-pointer group" },
                                                                        "actions": [{ "type": "click", "handler": "navigate", "params": { "path": "/board/notice/{{notice.id}}" } }],
                                                                        "children": [
                                                                            { "type": "basic", "name": "Span", "props": { "className": "badge badge-primary badge-sm shrink-0" }, "text": "$t:board.notice" },
                                                                            { "type": "basic", "name": "Span", "props": { "className": "text-sm font-medium text-base-content line-clamp-1 text-left group-hover:text-primary transition-colors" }, "text": "{{notice.title}}" },
                                                                            { "type": "basic", "name": "Span", "props": { "className": "text-xs text-base-content/35 shrink-0" }, "text": "{{notice.created_at_formatted ?? ''}}" }
                                                                        ]
                                                                    }
                                                                ]
                                                            }
                                                        ]
                                                    }
                                                ]
                                            },
                                            {
                                                "comment": "더보기 버튼",
                                                "type": "basic",
                                                "name": "Button",
                                                "props": { "className": "shrink-0 text-xs text-base-content/35 hover:text-primary transition-colors cursor-pointer flex items-center gap-1" },
                                                "actions": [{ "type": "click", "handler": "navigate", "params": { "path": "/board/notice" } }],
                                                "children": [
                                                    { "type": "basic", "name": "Span", "text": "$t:common.more" },
                                                    { "type": "basic", "name": "Icon", "props": { "name": "arrow-right", "className": "w-3 h-3" } }
                                                ]
                                            }
                                        ]
                                    },
                            {
                                "comment": "인기글 + 커뮤니티 요약 (2/3 + 1/3)",
                                "type": "basic",
                                "name": "Div",
                                "props": { "className": "grid grid-cols-3 gap-6 mb-10" },
                                "responsive": {
                                    "portable": { "props": { "className": "grid grid-cols-1 gap-6 mb-10" } }
                                },
                                "children": [
                                    {
                                        "type": "basic",
                                        "name": "Div",
                                        "props": { "className": "col-span-2" },
                                        "responsive": { "portable": { "props": { "className": "col-span-1" } } },
                                        "children": [{ "partial": "partials/home/_popular_posts.json" }]
                                    },
                                    { "partial": "partials/home/_community_summary.json" }
                                ]
                            },
                            {
                                "comment": "게시판 미리보기 (3컬럼)",
                                "type": "basic",
                                "name": "Div",
                                "props": { "className": "grid grid-cols-3 gap-6" },
                                "responsive": {
                                    "portable": { "props": { "className": "grid grid-cols-1 gap-6" } }
                                },
                                "children": [
                                    {
                                        "type": "basic",
                                        "name": "Div",
                                        "iteration": { "source": "{{home_boards.data ?? []}}", "item_var": "item" },
                                        "children": [{ "partial": "partials/home/_board_summary.json" }]
                                    }
                                ]
                            }
                        ]
                    }
                ]
            },
            {
                "comment": "=== 3: 갤러리 섹션 ===",
                "type": "layout",
                "name": "Container",
                "props": { "className": "px-4 section-breath" },
                "responsive": {
                    "tablet": { "props": { "className": "px-6 section-breath" } },
                    "desktop": { "props": { "className": "section-breath" } }
                },
                "children": [
                    { "partial": "partials/home/_gallery_section.json" }
                ]
            },
            {
                "comment": "=== 4: 신상품 섹션 (Surface Elevated) ===",
                "type": "basic",
                "name": "Div",
                "children": [
                    { "partial": "partials/home/_shop_section.json" }
                ]
            }
        ]
    }
}
