{
    "version": "1.0.0",
    "layout_name": "board/index",
    "permissions": [],
    "extends": "_user_base",
    "meta": {
        "seo": {
            "enabled": true,
            "data_sources": ["posts"],
            "priority": 0.6,
            "changefreq": "daily",
            "og": {
                "type": "website"
            },
            "structured_data": {
                "@type": "ItemList"
            }
        }
    },
    "data_sources": [
        {
            "id": "posts",
            "type": "api",
            "endpoint": "/api/modules/sirsoft-board/boards/{{route.slug}}/posts",
            "method": "GET",
            "params": {
                "page": "{{query.page ?? 1}}",
                "search": "{{query.search ?? ''}}",
                "category": "{{query.category ?? ''}}",
                "filters[0][field]": "{{query['filters[0][field]'] ?? ''}}",
                "filters[0][value]": "{{query['filters[0][value]'] ?? ''}}",
                "filters[0][operator]": "{{query['filters[0][operator]'] ?? ''}}",
                "del": "{{query.del ?? ''}}"
            },
            "auto_fetch": true,
            "auth_mode": "optional",
            "refetchOnMount": true,
            "errorHandling": {
                "401": {
                    "handler": "sequence",
                    "actions": [
                        { "handler": "toast", "params": { "type": "info", "message": "$t:board.login_required" } },
                        { "handler": "navigate", "params": { "path": "/login" } }
                    ]
                },
                "403": {
                    "handler": "showErrorPage",
                    "params": {
                        "target": "content"
                    }
                }
            },
            "onError": {
                "handler": "setState",
                "params": {
                    "target": "global",
                    "hasError": true
                }
            }
        },
        {
            "id": "board_detail",
            "type": "api",
            "endpoint": "/api/modules/sirsoft-board/boards/{{route.slug}}",
            "method": "GET",
            "auto_fetch": true,
            "loading_strategy": "progressive",
            "fallback": {
                "data": {}
            }
        }
    ],
    "slots": {
        "content": [
            {
                "comment": "=== Breadcrumb ===",
                "type": "basic",
                "name": "Nav",
                "props": { "className": "bc-nav", "aria-label": "Breadcrumb" },
                "children": [
                    { "type": "basic", "name": "Button", "props": { "className": "bc-link" }, "text": "$t:nav.home", "actions": [{ "type": "click", "handler": "navigate", "params": { "path": "/" } }] },
                    { "type": "basic", "name": "Span", "props": { "className": "bc-sep" }, "text": "/" },
                    { "type": "basic", "name": "Button", "props": { "className": "bc-link" }, "text": "$t:nav.community", "actions": [{ "type": "click", "handler": "navigate", "params": { "path": "/boards" } }] },
                    { "type": "basic", "name": "Span", "props": { "className": "bc-sep" }, "text": "/" },
                    { "type": "basic", "name": "Span", "props": { "className": "bc-current" }, "text": "{{board_detail.data.name}}" }
                ]
            },
            {
                "comment": "로딩 스켈레톤 + 오류 페이지 (type 불명 시점에도 표시 필요 → _type_renderer 밖에 배치)",
                "partial": "partials/board/index/_loading_error.json"
            },
            {
                "type": "layout",
                "name": "Container",
                "if": "{{posts?.data?.board}}",
                "props": {
                    "className": "py-8"
                },
                "children": [
                    {
                        "comment": "유형별 렌더러 (basic/gallery/card + fallback)",
                        "partial": "partials/board/index/_type_renderer.json"
                    }
                ]
            }
        ]
    }
}
