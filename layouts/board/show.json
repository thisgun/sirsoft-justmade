{
    "version": "1.0.0",
    "layout_name": "board/show",
    "permissions": [],
    "extends": "_user_base",
    "meta": {
        "seo": {
            "enabled": true,
            "data_sources": ["post"],
            "priority": 0.5,
            "changefreq": "monthly",
            "og": {
                "type": "article",
                "title": "{{post.data.title ?? ''}}",
                "description": "{{post.data.content ?? ''}}"
            },
            "structured_data": {
                "@type": "Article",
                "headline": "{{post.data.title ?? ''}}",
                "datePublished": "{{post.data.created_at ?? ''}}",
                "dateModified": "{{post.data.updated_at ?? ''}}"
            }
        }
    },
    "data_sources": [
        {
            "id": "post",
            "type": "api",
            "endpoint": "/api/modules/sirsoft-board/boards/{{route.slug}}/posts/{{route.id}}",
            "method": "GET",
            "params": {
                "del_cmt": "{{query.del_cmt ?? ''}}"
            },
            "auto_fetch": true,
            "auth_mode": "optional",
            "refetchOnMount": true,
            "errorHandling": {
                "401": {
                    "handler": "sequence",
                    "actions": [
                        { "handler": "toast", "params": { "type": "info", "message": "$t:board.login_required" } },
                        { "handler": "navigate", "params": { "path": "/login" } }
                    ]
                },
                "403": {
                    "handler": "showErrorPage",
                    "params": {
                        "target": "content"
                    }
                },
                "404": {
                    "handler": "showErrorPage",
                    "params": {
                        "target": "content"
                    }
                }
            }
        }
    ],
    "computed": {
        "commentRootMap": "{{(post?.data?.comments ?? []).reduce((map, c) => ({...map, [c.id]: c.depth === 0 ? c.id : (map[c.parent_id] ?? c.parent_id)}), {})}}"
    },
    "slots": {
        "content": [
            {
                "comment": "=== Breadcrumb ===",
                "type": "basic",
                "name": "Nav",
                "props": { "className": "bc-nav", "aria-label": "Breadcrumb" },
                "children": [
                    { "type": "basic", "name": "Button", "props": { "className": "bc-link" }, "text": "$t:nav.home", "actions": [{ "type": "click", "handler": "navigate", "params": { "path": "/" } }] },
                    { "type": "basic", "name": "Span", "props": { "className": "bc-sep" }, "text": "/" },
                    { "type": "basic", "name": "Button", "props": { "className": "bc-link" }, "text": "{{post.data.board.name}}", "actions": [{ "type": "click", "handler": "navigate", "params": { "path": "/board/{{post.data.board.slug ?? route.slug}}" } }] },
                    { "type": "basic", "name": "Span", "props": { "className": "bc-sep" }, "text": "/" },
                    { "type": "basic", "name": "Span", "props": { "className": "bc-current" }, "text": "{{post.data.title}}" }
                ]
            },
            {
                "type": "layout",
                "name": "Container",
                "props": {
                    "className": "py-8"
                },
                "children": [
                    {
                        "partial": "partials/board/show/_type_renderer.json"
                    }
                ]
            }
        ]
    },
    "modals": [
        {
            "partial": "partials/board/show/modals/_modal_delete.json"
        },
        {
            "partial": "partials/board/show/modals/_modal_report.json"
        },
        {
            "partial": "partials/board/show/modals/_password_verify_modal.json"
        },
        {
            "partial": "partials/board/show/modals/_modal_image_viewer.json"
        }
    ]
}
