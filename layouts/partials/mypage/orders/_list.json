                    }
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Div",
                      "children": [
                        {
                          "type": "basic",
                          "name": "P",
                          "props": { "className": "text-sm text-gray-500 dark:text-gray-400" },
                          "responsive": {
                            "portable": {
                              "props": { "className": "text-xs text-gray-500 dark:text-gray-400" }
                            }
                          },
                          "text": "{{order.ordered_at_formatted ?? ''}}"
                        },
                        {
                          "type": "basic",
                          "name": "P",
                          "props": { "className": "text-sm font-medium text-gray-900 dark:text-white" },
                          "responsive": {
                            "portable": {
                              "props": { "className": "text-xs font-medium text-gray-900 dark:text-white" }
                            }
                          },
                          "text": "{{order.order_number}}"
                        }
                      ]
                    },
                    {
                      "comment": "주문상태 배지",
                      "type": "basic",
                      "name": "Span",
                      "classMap": {
                        "base": "inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium whitespace-nowrap",
                        "key": "{{order.status}}",
                        "variants": {
                          "pending_payment": "bg-yellow-100 text-yellow-800 dark:bg-yellow-900/30 dark:text-yellow-400",
                          "payment_complete": "bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-400",
                          "preparing": "bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-400",
                          "shipping_ready": "bg-blue-100 text-blue-800 dark:bg-blue-900/30 dark:text-blue-400",
                          "shipping": "bg-indigo-100 text-indigo-800 dark:bg-indigo-900/30 dark:text-indigo-400",
                          "delivered": "bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400",
                          "confirmed": "bg-green-100 text-green-800 dark:bg-green-900/30 dark:text-green-400",
                          "cancelled": "bg-red-100 text-red-800 dark:bg-red-900/30 dark:text-red-400"
                        },
                        "default": "bg-gray-100 text-gray-800 dark:bg-gray-700 dark:text-gray-300"
                      },
                      "text": "{{order.status_label}}"
                    }
                  ]
                },
                {
                  "comment": "주문 상품 목록",
                  "type": "basic",
                  "name": "Div",
                  "props": { "className": "space-y-3" },
                  "responsive": {
                    "portable": {
                      "props": { "className": "space-y-2" }
                    }
                  },
                  "iteration": { "source": "{{order.items ?? []}}", "item_var": "item" },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": { "className": "flex gap-3" },
                      "children": [
                        {
                          "comment": "상품 이미지",
                          "type": "basic",
                          "name": "Div",
                          "props": { "className": "w-16 h-16 rounded-lg overflow-hidden bg-gray-100 dark:bg-gray-700 flex-shrink-0" },
                          "responsive": {
                            "portable": {
                              "props": { "className": "w-14 h-14 rounded-lg overflow-hidden bg-gray-100 dark:bg-gray-700 flex-shrink-0" }
                            }
                          },
                          "children": [
                            {
                              "type": "basic",
                              "name": "Img",
                              "if": "{{item.thumbnail_url}}",
                              "props": { "src": "{{item.thumbnail_url}}", "alt": "{{item.product_name}}", "className": "w-full h-full object-cover" }
                            },
                            {
                              "type": "basic",
                              "name": "Div",
                              "if": "{{!item.thumbnail_url}}",
                              "props": { "className": "w-full h-full flex items-center justify-center" },
                              "children": [
                                {
                                  "type": "basic",
                                  "name": "Icon",
                                  "props": { "name": "image", "size": "lg", "className": "text-gray-400 dark:text-gray-500" }
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "comment": "상품 정보",
                          "type": "basic",
                          "name": "Div",
                          "props": { "className": "flex-1 min-w-0" },
                          "children": [
                            {
                              "type": "basic",
                              "name": "P",
                              "props": { "className": "text-sm font-medium text-gray-900 dark:text-white truncate" },
                              "responsive": {
                                "portable": {
                                  "props": { "className": "text-xs font-medium text-gray-900 dark:text-white truncate" }
                                }
                              },
                              "text": "{{item.product_name}}"
                            },
                            {
                              "type": "basic",
                              "name": "P",
                              "props": { "className": "text-xs text-gray-500 dark:text-gray-400 mt-0.5" },
                              "text": "{{item.product_option_name}}"
                            },
                            {
                              "type": "basic",
                              "name": "P",
                              "props": { "className": "text-xs text-gray-500 dark:text-gray-400 mt-1" },
                              "responsive": {
                                "portable": {
                                  "props": { "className": "text-xs text-gray-500 dark:text-gray-400 mt-0.5" }
                                }
                              },
                              "text": "{{item.mc_unit_price?.[_global.preferredCurrency ?? 'KRW']?.formatted ?? item.unit_price_formatted}} × {{item.quantity}}$t:shop.count_unit"
                            },
                            {
                              "comment": "옵션 소계",
                              "type": "basic",
                              "name": "P",
                              "props": { "className": "text-sm font-medium text-gray-900 dark:text-white mt-0.5" },
                              "responsive": {
                                "portable": {
                                  "props": { "className": "text-xs font-medium text-gray-900 dark:text-white mt-0.5" }
                                }
                              },
                              "text": "{{item.mc_subtotal_price?.[_global.preferredCurrency ?? 'KRW']?.formatted ?? item.subtotal_price_formatted}}"
                            },
                            {
                              "comment": "보조 통화들 (선택된 통화 제외)",
                              "type": "basic",
                              "name": "Div",
                              "props": { "className": "flex flex-wrap gap-x-2 mt-0.5" },
                              "iteration": {
                                "source": "{{Object.entries(item.mc_subtotal_price ?? {}).filter(([code]) => code !== (_global.preferredCurrency ?? 'KRW'))}}",
                                "item_var": "currency"
                              },
                              "children": [
                                {
                                  "type": "basic",
                                  "name": "Span",
                                  "props": { "className": "text-xs text-gray-500 dark:text-gray-400" },
                                  "text": "{{currency[1]?.formatted}}"
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                },
                {
                  "comment": "배송비 + 결제금액 + 상세보기",
                  "type": "basic",
                  "name": "Div",
                  "props": { "className": "flex items-center justify-between mt-4 pt-4 border-t border-gray-100 dark:border-gray-700" },
                  "responsive": {
                    "portable": {
                      "props": { "className": "flex items-center justify-between mt-3 pt-3 border-t border-gray-100 dark:border-gray-700" }
                    }
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Div",
                      "children": [
                        {
                          "comment": "배송비",
                          "type": "basic",
                          "name": "Div",
                          "props": { "className": "flex items-center gap-2 mb-1" },
                          "children": [
                            {
                              "type": "basic",
                              "name": "Span",
                              "props": { "className": "text-xs text-gray-500 dark:text-gray-400" },
                              "text": "$t:mypage.orders.shipping_fee"
                            },
                            {
                              "type": "basic",
                              "name": "Span",
                              "if": "{{order.total_shipping_amount > 0}}",
                              "props": { "className": "text-xs text-gray-600 dark:text-gray-300" },
                              "text": "+{{order.mc_total_shipping_amount?.[_global.preferredCurrency ?? 'KRW']?.formatted ?? order.total_shipping_amount_formatted}}"
                            },
                            {
                              "type": "basic",
                              "name": "Span",
                              "if": "{{!order.total_shipping_amount || order.total_shipping_amount == 0}}",
                              "props": { "className": "text-xs text-green-600 dark:text-green-400" },
                              "text": "$t:mypage.orders.free_shipping"
                            }
                          ]
                        },
                        {
                          "type": "basic",
                          "name": "P",
                          "props": { "className": "text-xs text-gray-500 dark:text-gray-400" },
                          "text": "$t:mypage.orders.total_amount"
                        },
                        {
                          "type": "basic",
                          "name": "P",
                          "props": { "className": "text-lg font-bold text-gray-900 dark:text-white" },
                          "responsive": {
                            "portable": {
                              "props": { "className": "text-base font-bold text-gray-900 dark:text-white" }
                            }
                          },
                          "text": "{{order.mc_total_amount?.[_global.preferredCurrency ?? 'KRW']?.formatted ?? order.total_amount_formatted}}"
                        },
                        {
                          "comment": "보조 통화들 (선택된 통화 제외)",
                          "type": "basic",
                          "name": "Div",
                          "props": { "className": "flex flex-wrap gap-x-2" },
                          "iteration": {
                            "source": "{{Object.entries(order.mc_total_amount ?? {}).filter(([code]) => code !== (_global.preferredCurrency ?? 'KRW'))}}",
                            "item_var": "currency"
                          },
                          "children": [
                            {
                              "type": "basic",
                              "name": "Span",
                              "props": { "className": "text-xs text-gray-500 dark:text-gray-400" },
                              "text": "{{currency[1]?.formatted}}"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Button",
                      "props": {
                        "type": "button",
                        "className": "inline-flex items-center gap-1.5 px-4 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-gray-100 dark:bg-gray-700 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors cursor-pointer"
                      },
                      "responsive": {
                        "portable": {
                          "props": {
                            "type": "button",
                            "className": "inline-flex items-center gap-1 px-3 py-1.5 text-xs font-medium text-gray-700 dark:text-gray-300 bg-gray-100 dark:bg-gray-700 rounded-lg hover:bg-gray-200 dark:hover:bg-gray-600 transition-colors cursor-pointer"
                          }
                        }
                      },
                      "actions": [
                        {
                          "type": "click",
                          "handler": "navigate",
                          "params": { "path": "/mypage/orders/{{order.order_number}}" }
                        }
                      ],
                      "children": [
                        { "type": "basic", "name": "Icon", "props": { "name": "eye", "size": "sm" } },
                        { "type": "basic", "name": "Span", "text": "$t:mypage.orders.view_detail" }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "comment": "주문 없음",
          "type": "basic",
          "name": "Div",
          "if": "{{!orders.data.data || orders.data.data.length === 0}}",
          "props": { "className": "card bg-base-100 shadow-sm p-8 text-center" },
          "responsive": {
            "portable": {
              "props": { "className": "card bg-base-100 shadow-sm p-6 text-center" }
            }
          },
          "children": [
            {
              "type": "basic",
              "name": "Icon",
              "props": { "name": "package", "size": "3x", "className": "mx-auto text-gray-300 dark:text-gray-600 mb-3" },
              "responsive": {
                "portable": {
                  "props": { "name": "package", "size": "2x", "className": "mx-auto text-gray-300 dark:text-gray-600 mb-2" }
                }
              }
            },
            {
              "type": "basic",
              "name": "P",
              "props": { "className": "text-gray-500 dark:text-gray-400" },
              "responsive": {
                "portable": {
                  "props": { "className": "text-sm text-gray-500 dark:text-gray-400" }
                }
              },
              "text": "$t:mypage.orders.empty"
            },
            {
              "type": "basic",
              "name": "Button",
              "props": {
                "type": "button",
                "className": "inline-block mt-4 px-4 py-2 bg-gray-900 dark:bg-white text-white dark:text-gray-900 rounded-lg text-sm font-medium cursor-pointer"
              },
              "responsive": {
                "portable": {
                  "props": {
                    "type": "button",
                    "className": "inline-block mt-3 px-3 py-1.5 bg-gray-900 dark:bg-white text-white dark:text-gray-900 rounded-lg text-xs font-medium cursor-pointer"
                  }
                }
              },
              "actions": [
                {
                  "type": "click",
                  "handler": "navigate",
                  "params": { "path": "{{_global.shopBase}}/products" }
                }
              ],
              "text": "$t:mypage.orders.go_shopping"
            }
          ]
        },
        {
          "comment": "페이지네이션",
          "type": "composite",
          "name": "Pagination",
          "if": "{{orders.data.pagination.last_page > 1}}",
          "props": {
            "currentPage": "{{orders.data.pagination.current_page}}",
            "totalPages": "{{orders.data.pagination.last_page}}",
            "className": "mt-4"
          },
          "responsive": {
            "portable": {
              "props": {
                "currentPage": "{{orders.data.pagination.current_page}}",
                "totalPages": "{{orders.data.pagination.last_page}}",
                "className": "mt-3"
              }
            }
          },
          "actions": [
            {
              "event": "onPageChange",
              "handler": "sequence",
              "actions": [
                { "handler": "setState", "params": { "target": "local", "ordersPage": "{{$args[0]}}" } },
                { "handler": "navigate", "params": { "path": "/mypage/orders", "replace": true, "mergeQuery": true, "query": { "page": "{{$args[0]}}" } } }
              ]
            }
          ]
        }
      ]
    }
  ]
}
