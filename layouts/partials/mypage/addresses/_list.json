{
  "meta": {
    "is_partial": true,
    "description": "마이페이지 배송지 관리 탭 - Nexibase 스타일"
  },
  "type": "basic",
  "name": "Div",
  "blur_until_loaded": {
    "enabled": true,
    "data_sources": "addresses"
  },
  "props": { "className": "mt-6" },
  "responsive": {
    "portable": {
      "props": { "className": "mt-4" }
    }
  },
  "children": [
    {
      "comment": "헤더: 새 주소 추가 버튼",
      "type": "basic",
      "name": "Div",
      "props": { "className": "flex justify-end mb-4" },
      "children": [
        {
          "type": "basic",
          "name": "Button",
          "props": { "className": "inline-flex items-center gap-2 px-4 py-2 bg-gray-900 dark:bg-white text-white dark:text-gray-900 rounded-lg text-sm font-medium hover:bg-gray-800 dark:hover:bg-gray-100 transition-colors" },
          "responsive": {
            "portable": {
              "props": { "className": "inline-flex items-center gap-1.5 px-3 py-2 bg-gray-900 dark:bg-white text-white dark:text-gray-900 rounded-lg text-sm font-medium hover:bg-gray-800 dark:hover:bg-gray-100 transition-colors" }
            }
          },
          "children": [
            { "type": "basic", "name": "Icon", "props": { "name": "plus", "className": "w-4 h-4" } },
            { "type": "basic", "name": "Span", "text": "$t:mypage.addresses.add" }
          ],
          "actions": [
            {
              "type": "click",
              "handler": "sequence",
              "actions": [
                { "handler": "setState", "params": { "target": "global", "editingAddress": { "is_default": false } } },
                { "handler": "openModal", "target": "addressModal" }
              ]
            }
          ]
        }
      ]
    },
    {
      "comment": "배송지 목록",
      "type": "basic",
      "name": "Div",
      "if": "{{(addresses?.data?.addresses?.data ?? []).length > 0}}",
      "props": { "className": "space-y-3" },
      "responsive": {
        "portable": {
          "props": { "className": "space-y-2" }
        }
      },
      "children": [
        {
          "comment": "배송지 카드",
          "type": "basic",
          "name": "Div",
          "iteration": { "source": "{{addresses?.data?.addresses?.data ?? []}}", "item_var": "address", "index_var": "addressIdx" },
          "props": { "className": "card bg-base-100 shadow-sm p-4" },
          "responsive": {
            "portable": {
              "props": { "className": "card bg-base-100 shadow-sm p-3" }
            }
          },
          "children": [
            {
              "comment": "헤더: 라벨 + 기본배송지 뱃지 + 수정/삭제 버튼",
              "type": "basic",
              "name": "Div",
              "props": { "className": "flex items-center justify-between mb-2" },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "props": { "className": "flex items-center gap-2 flex-wrap" },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": { "className": "font-medium text-gray-900 dark:text-white" },
                      "text": "{{$localized(address.name)}}"
                    },
                    {
                      "comment": "기본 배송지 뱃지 - 검정 배경 + 흰 텍스트 + 별 아이콘",
                      "type": "basic",
                      "name": "Span",
                      "if": "{{address.is_default}}",
                      "props": { "className": "inline-flex items-center gap-1 px-2 py-0.5 text-xs bg-gray-900 dark:bg-white text-white dark:text-gray-900 rounded font-medium" },
                      "children": [
                        { "type": "basic", "name": "Icon", "props": { "name": "star", "className": "w-3 h-3" } },
                        { "type": "basic", "name": "Span", "text": "$t:mypage.addresses.default" }
                      ]
                    }
                  ]
                },
                {
                  "comment": "수정/삭제 텍스트 버튼",
                  "type": "basic",
                  "name": "Div",
                  "props": { "className": "flex items-center gap-2" },
                  "children": [
                    {
                      "comment": "수정 버튼",
                      "type": "basic",
                      "name": "Button",
                      "props": {
                        "type": "button",
                        "className": "px-3 py-1.5 text-sm text-gray-600 dark:text-gray-400 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors"
                      },
                      "text": "$t:common.edit",
                      "actions": [
                        {
                          "type": "click",
                          "handler": "sequence",
                          "actions": [
                            { "handler": "setState", "params": { "target": "global", "editingAddress": "{{address}}" } },
                            { "handler": "openModal", "target": "addressModal" }
                          ]
                        }
                      ]
                    },
                    {
                      "comment": "삭제 버튼 - 기본 배송지는 삭제 불가",
                      "type": "basic",
                      "name": "Button",
                      "if": "{{address.abilities?.can_delete === true}}",
                      "props": {
                        "type": "button",
                        "className": "px-3 py-1.5 text-sm text-red-600 dark:text-red-400 border border-red-300 dark:border-red-600 rounded-lg hover:bg-red-50 dark:hover:bg-red-900/20 transition-colors"
                      },
                      "text": "$t:common.delete",
                      "actions": [
                        {
                          "type": "click",
                          "handler": "sequence",
                          "actions": [
                            { "handler": "setState", "params": { "target": "global", "deletingAddressId": "{{address.id}}" } },
                            { "handler": "openModal", "target": "confirmDeleteAddressModal" }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "comment": "수령인 / 연락처",
              "type": "basic",
              "name": "P",
              "props": { "className": "text-sm text-gray-600 dark:text-gray-400 mb-1" },
              "text": "{{address.recipient_name}} | {{address.recipient_phone}}"
            },
            {
              "comment": "주소",
              "type": "basic",
              "name": "P",
              "props": { "className": "text-sm text-gray-600 dark:text-gray-400 break-words" },
              "text": "[{{address.zipcode}}] {{address.address}} {{address.address_detail}}"
            }
          ]
        }
      ]
    },
    {
      "comment": "빈 상태 - 배송지 없음",
      "type": "basic",
      "name": "Div",
      "if": "{{!(addresses?.data?.addresses?.data ?? []).length}}",
      "props": { "className": "card bg-base-100 shadow-sm p-12 text-center" },
      "responsive": {
        "portable": {
          "props": { "className": "card bg-base-100 shadow-sm p-8 text-center" }
        }
      },
      "children": [
        {
          "type": "basic",
          "name": "Icon",
          "props": { "name": "map-pin", "className": "w-16 h-16 mx-auto text-gray-300 dark:text-gray-600 mb-4" },
          "responsive": {
            "portable": {
              "props": { "name": "map-pin", "className": "w-12 h-12 mx-auto text-gray-300 dark:text-gray-600 mb-3" }
            }
          }
        },
        {
          "type": "basic",
          "name": "P",
          "props": { "className": "text-gray-500 dark:text-gray-400 mb-4" },
          "text": "$t:mypage.addresses.empty"
        },
        {
          "type": "basic",
          "name": "Button",
          "props": { "className": "inline-flex items-center gap-2 px-4 py-2 bg-gray-900 dark:bg-white text-white dark:text-gray-900 rounded-lg text-sm font-medium hover:bg-gray-800 dark:hover:bg-gray-100 transition-colors" },
          "children": [
            { "type": "basic", "name": "Icon", "props": { "name": "plus", "className": "w-4 h-4" } },
            { "type": "basic", "name": "Span", "text": "$t:mypage.addresses.add" }
          ],
          "actions": [
            {
              "type": "click",
              "handler": "sequence",
              "actions": [
                { "handler": "setState", "params": { "target": "global", "editingAddress": { "is_default": false } } },
                { "handler": "openModal", "target": "addressModal" }
              ]
            }
          ]
        }
      ]
    }
  ]
}
