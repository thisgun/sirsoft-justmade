                  "name": "Span",
                  "text": "$t:mypage.profile.edit_button"
                }
              ],
              "actions": [
                {
                  "type": "click",
                  "handler": "navigate",
                  "params": {
                    "path": "/mypage/profile/edit"
                  }
                }
              ]
            }
          ]
