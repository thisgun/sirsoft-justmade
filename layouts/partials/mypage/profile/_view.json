    {
      "comment": "프로필 카드 - 아바타 + 이름 + 이메일 + 가입일/마지막 로그인",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "card bg-base-100 shadow-sm p-6"
      },
      "responsive": {
        "portable": {
          "props": {
            "className": "card bg-base-100 shadow-sm p-4"
          }
        }
      },
      "children": [
        {
          "comment": "데스크탑: 가로 배치 (아바타 + 정보)",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "flex gap-4 items-start"
          },
          "responsive": {
            "portable": {
              "props": {
                "className": "flex flex-col items-center gap-4"
              }
            }
          },
          "children": [
            {
              "comment": "프로필 아바타 - AvatarUploader 컴포넌트 (xl = 96px)",
              "type": "composite",
              "name": "AvatarUploader",
              "props": {
                "src": "{{user.data?.avatar}}",
                "fallbackText": "{{user.data?.name?.charAt(0) ?? 'U'}}",
                "size": "xl",
                "showDeleteButton": true,
                "confirmDelete": true,
                "uploadSuccessActions": [
                  { "handler": "refetchDataSource", "params": { "dataSourceId": "user" } },
                  { "handler": "refetchDataSource", "params": { "dataSourceId": "current_user" } }
                ],
                "deleteSuccessActions": [
                  { "handler": "refetchDataSource", "params": { "dataSourceId": "user" } },
                  { "handler": "refetchDataSource", "params": { "dataSourceId": "current_user" } }
                ]
              },
              "responsive": {
                "portable": {
                  "props": {
                    "size": "lg"
                  }
                }
              }
            },
            {
              "comment": "기본 정보 - 데스크탑: 좌측 정렬, 모바일: 중앙 정렬",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex-1 space-y-3 py-2"
              },
              "responsive": {
                "portable": {
                  "props": {
                    "className": "w-full space-y-3 text-center"
                  }
                }
              },
              "children": [
                {
                  "comment": "이름 + 닉네임 (하단 정렬)",
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex items-end gap-2"
                  },
                  "responsive": {
                    "portable": {
                      "props": {
                        "className": "flex items-end justify-center gap-2"
                      }
                    }
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "text-2xl font-semibold text-gray-900 dark:text-white leading-none"
                      },
                      "responsive": {
                        "portable": {
                          "props": {
                            "className": "text-xl font-semibold text-gray-900 dark:text-white leading-none"
                          }
                        }
                      },
                      "text": "{{user.data?.name ?? '-'}}"
                    },
                    {
                      "comment": "닉네임 (있는 경우만 표시)",
                      "if": "{{user.data?.nickname}}",
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "text-base text-gray-500 dark:text-gray-400 leading-none"
                      },
                      "text": "({{user.data?.nickname}})"
                    },
                    {
                      "comment": "상태 배지 (Active가 아닌 경우만 표시)",
                      "if": "{{user.data?.status && user.data?.status !== 'active'}}",
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "{{user.data?.status_variant === 'secondary' ? 'inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-700 dark:bg-gray-700 dark:text-gray-300' : user.data?.status_variant === 'danger' ? 'inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-700 dark:bg-red-900 dark:text-red-300' : 'inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-700 dark:bg-yellow-900 dark:text-yellow-300'}}"
                      },
                      "text": "{{user.data?.status_label}}"
                    }
                  ]
                },
                {
                  "comment": "이메일",
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "text-base text-gray-600 dark:text-gray-300"
                  },
                  "responsive": {
                    "portable": {
                      "props": {
                        "className": "text-sm text-gray-600 dark:text-gray-300"
                      }
                    }
                  },
                  "text": "{{user.data?.email ?? '-'}}"
                },
                {
                  "comment": "구분선",
                  "type": "basic",
                  "name": "Hr",
                  "props": {
                    "className": "border-gray-200 dark:border-gray-700 my-2"
                  }
                },
                {
                  "comment": "가입일 / 마지막 로그인",
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex flex-wrap gap-x-6 gap-y-1 text-sm text-gray-500 dark:text-gray-400"
                  },
                  "responsive": {
                    "portable": {
                      "props": {
                        "className": "flex flex-col gap-1 text-sm text-gray-500 dark:text-gray-400"
                      }
                    }
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Div",
                      "children": [
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "text-gray-500 dark:text-gray-400"
                          },
                          "text": "$t:mypage.profile.joined_at"
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "ml-2 text-purple-600 dark:text-purple-400 font-mono"
                          },
                          "text": "{{user.data?.created_at ?? '-'}}"
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Div",
                      "children": [
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "text-gray-500 dark:text-gray-400"
                          },
                          "text": "$t:mypage.profile.last_login"
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "ml-2 text-purple-600 dark:text-purple-400",
                            "title": "{{user.data?.last_login_at ?? ''}}"
                          },
                          "text": "{{user.data?.last_login_human ?? '-'}}"
                        }
                      ]
                    },
                    {
                      "comment": "탈퇴 일시 (탈퇴 상태인 경우만 표시)",
                      "if": "{{user.data?.status === 'withdrawn' && user.data?.withdrawn_at}}",
                      "type": "basic",
                      "name": "Div",
                      "children": [
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "text-gray-500 dark:text-gray-400"
                          },
                          "text": "$t:mypage.profile.withdrawn_at"
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "ml-2 text-red-600 dark:text-red-400 font-mono"
                          },
                          "text": "{{user.data?.withdrawn_at}}"
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
