              },
              "children": [
                {
                  "type": "basic",
                  "name": "Icon",
                  "props": {
                    "name": "lock",
                    "size": "sm"
                  }
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "text": "$t:mypage.profile.change_password_button"
                }
              ],
              "actions": [
                {
                  "type": "click",
                  "handler": "navigate",
                  "params": {
                    "path": "/mypage/change-password"
                  }
                }
              ]
            },
            {
              "comment": "수정하기 버튼 - 편집 페이지로 이동",
              "type": "basic",
              "name": "Button",
              "props": {
                "type": "button",
