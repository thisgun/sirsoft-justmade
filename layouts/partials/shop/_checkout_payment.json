{
  "meta": {
    "is_partial": true,
    "description": "결제 방법 선택 섹션 (PC/모바일 반응형) - 환경설정 활성 결제수단을 동적 렌더링"
  },
  "type": "basic",
  "name": "Div",
  "props": { "className": "card bg-base-100 shadow-sm p-6" },
  "responsive": {
    "portable": {
      "props": { "className": "card bg-base-100 shadow-sm p-4" }
    }
  },
  "children": [
    {
      "comment": "섹션 헤더",
      "type": "basic",
      "name": "Div",
      "props": { "className": "flex items-center gap-2 mb-4 pb-4 border-b border-gray-200 dark:border-gray-700" },
      "responsive": {
        "portable": {
          "props": { "className": "flex items-center gap-2 mb-3 pb-3 border-b border-gray-200 dark:border-gray-700" }
        }
      },
      "children": [
        { "type": "basic", "name": "Icon", "props": { "name": "credit-card", "className": "w-5 h-5 text-gray-700 dark:text-gray-300" } },
        {
          "type": "basic",
          "name": "H2",
          "props": { "className": "text-lg font-semibold text-gray-900 dark:text-white" },
          "responsive": {
            "portable": {
              "props": { "className": "text-base font-semibold text-gray-900 dark:text-white" }
            }
          },
          "text": "$t:shop.checkout.payment_method"
        }
      ]
    },
    {
      "comment": "결제 방법 선택 카드 (활성화된 결제수단 동적 렌더링)",
      "type": "layout",
      "name": "Grid",
      "props": { "cols": 3, "gap": 4, "className": "mb-4" },
      "responsive": {
        "portable": {
          "props": { "cols": 1, "gap": 3, "className": "mb-3" }
        }
      },
      "children": [
        {
          "type": "basic",
          "name": "Button",
          "iteration": {
            "source": "{{(paymentSettings.data?.order_settings?.payment_methods ?? []).filter(m => m.is_active)}}",
            "item_var": "method",
            "index_var": "methodIdx"
          },
          "props": {
            "type": "button",
            "className": "{{_computed.selectedPaymentMethod === method.id ? 'p-4 border-2 border-gray-900 dark:border-white rounded-lg text-left' : 'p-4 border border-gray-300 dark:border-gray-600 rounded-lg text-left hover:border-gray-400 dark:hover:border-gray-500'}}"
          },
          "responsive": {
            "portable": {
              "props": {
                "className": "{{_computed.selectedPaymentMethod === method.id ? 'p-3 border-2 border-gray-900 dark:border-white rounded-lg text-left' : 'p-3 border border-gray-300 dark:border-gray-600 rounded-lg text-left hover:border-gray-400 dark:hover:border-gray-500'}}"
              }
            }
          },
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": { "className": "flex items-center gap-3" },
              "responsive": {
                "portable": {
                  "props": { "className": "flex items-center gap-2" }
                }
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Icon",
                  "props": {
                    "name": "{{method._cached_icon ?? 'circle-question'}}",
                    "className": "w-10 h-10 text-gray-700 dark:text-gray-300"
                  },
                  "responsive": {
                    "portable": {
                      "props": {
                        "name": "{{method._cached_icon ?? 'circle-question'}}",
                        "className": "w-8 h-8 text-gray-700 dark:text-gray-300"
                      }
                    }
                  }
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "children": [
                    {
                      "type": "basic",
                      "name": "P",
                      "props": { "className": "font-medium text-gray-900 dark:text-white" },
                      "responsive": {
                        "portable": {
                          "props": { "className": "font-medium text-sm text-gray-900 dark:text-white" }
                        }
                      },
                      "text": "{{$localized(method._cached_name) ?? method.id}}"
                    },
                    {
                      "type": "basic",
                      "name": "P",
                      "if": "{{$localized(method._cached_description)}}",
                      "props": { "className": "text-sm text-gray-500 dark:text-gray-400" },
                      "responsive": {
                        "portable": {
                          "props": { "className": "text-xs text-gray-500 dark:text-gray-400" }
                        }
                      },
                      "text": "{{$localized(method._cached_description)}}"
                    }
                  ]
                }
              ]
            }
          ],
          "actions": [
            {
              "type": "click",
              "handler": "sirsoft-pay-nicepayments.setPaymentMethod",
              "params": { "paymentMethod": "{{method.id}}" }
            }
          ]
        }
      ]
    },
    {
      "comment": "카드결제 선택 시 안내",
      "type": "basic",
      "name": "Div",
      "if": "{{_computed.selectedPaymentMethod === 'card'}}",
      "props": { "className": "p-4 bg-gray-100 dark:bg-gray-700 rounded-lg" },
      "responsive": {
        "portable": {
          "props": { "className": "p-3 bg-gray-100 dark:bg-gray-700 rounded-lg" }
        }
      },
      "children": [
        {
          "type": "basic",
          "name": "P",
          "props": { "className": "text-sm text-gray-500 dark:text-gray-400" },
          "responsive": {
            "portable": {
              "props": { "className": "text-xs text-gray-500 dark:text-gray-400" }
            }
          },
          "text": "$t:shop.checkout.card_payment_info"
        }
      ]
    },
    {
      "comment": "가상계좌 선택 시 안내",
      "type": "basic",
      "name": "Div",
      "if": "{{_computed.selectedPaymentMethod === 'vbank'}}",
      "props": { "className": "p-4 bg-blue-50 dark:bg-blue-900/30 rounded-lg" },
      "responsive": {
        "portable": {
          "props": { "className": "p-3 bg-blue-50 dark:bg-blue-900/30 rounded-lg" }
        }
      },
      "children": [
        {
          "type": "basic",
          "name": "P",
          "props": { "className": "text-sm text-blue-700 dark:text-blue-300 mb-2" },
          "text": "$t:shop.checkout.vbank_info"
        },
        {
          "type": "basic",
          "name": "P",
          "props": { "className": "text-xs text-blue-600 dark:text-blue-400" },
          "text": "$t:shop.checkout.vbank_due_notice|days={{paymentSettings.data?.order_settings?.vbank_due_days ?? 3}}"
        },
        {
          "comment": "입금자명 입력",
          "type": "basic",
          "name": "Div",
          "props": { "className": "mt-4" },
          "responsive": {
            "portable": {
              "props": { "className": "mt-3" }
            }
          },
          "children": [
            {
              "type": "basic",
              "name": "Label",
              "props": { "className": "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" },
              "text": "$t:shop.checkout.depositor_name"
            },
            {
              "type": "basic",
              "name": "Input",
              "props": {
                "type": "text",
                "name": "depositor_name",
                "value": "{{_local.depositorName ?? _local.orderer?.name ?? ''}}",
                "placeholder": "$t:shop.checkout.depositor_name_placeholder",
                "className": "w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-base-100 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500"
              },
              "responsive": {
                "portable": {
                  "props": {
                    "className": "w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-base-100 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 text-sm"
                  }
                }
              },
              "actions": [
                {
                  "type": "change",
                  "handler": "setState",
                  "params": { "target": "local", "depositorName": "{{$event.target.value}}" }
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "comment": "무통장입금 선택 시 계좌 선택 및 입금자명",
      "type": "basic",
      "name": "Div",
      "if": "{{_computed.selectedPaymentMethod === 'dbank'}}",
      "props": { "className": "p-4 bg-gray-50 dark:bg-gray-700/50 rounded-lg" },
      "responsive": {
        "portable": {
          "props": { "className": "p-3 bg-gray-50 dark:bg-gray-700/50 rounded-lg" }
        }
      },
      "children": [
        {
          "type": "basic",
          "name": "P",
          "props": { "className": "text-sm text-gray-600 dark:text-gray-400 mb-3" },
          "responsive": {
            "portable": {
              "props": { "className": "text-xs text-gray-600 dark:text-gray-400 mb-2" }
            }
          },
          "text": "$t:shop.checkout.dbank_info"
        },
        {
          "comment": "계좌 선택",
          "type": "basic",
          "name": "Div",
          "props": { "className": "mb-4" },
          "children": [
            {
              "type": "basic",
              "name": "Label",
              "props": { "className": "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2" },
              "children": [
                { "type": "basic", "name": "Span", "text": "$t:shop.checkout.dbank_select_account" },
                { "type": "basic", "name": "Span", "props": { "className": "text-red-500 ml-1" }, "text": "*" }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "props": { "className": "{{_local.errors?.['dbank.bank_code'] ? 'space-y-2 p-2 border-2 border-red-500 rounded-lg' : 'space-y-2'}}" },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "iteration": {
                    "source": "{{paymentSettings.data?.order_settings?.bank_accounts?.filter(b => b.is_active) ?? []}}",
                    "item_var": "bank",
                    "index_var": "bankIdx"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Button",
                      "props": {
                        "type": "button",
                        "className": "{{_local.selectedDbank?.bank_code === bank.bank_code ? 'w-full p-3 border-2 border-blue-500 bg-blue-50 dark:bg-blue-900/30 rounded-lg text-left' : 'w-full p-3 border border-gray-300 dark:border-gray-600 rounded-lg text-left hover:bg-gray-50 dark:hover:bg-gray-700'}}"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Div",
                          "props": { "className": "flex justify-between items-center" },
                          "children": [
                            {
                              "type": "basic",
                              "name": "Div",
                              "children": [
                                {
                                  "type": "basic",
                                  "name": "P",
                                  "props": { "className": "font-medium text-gray-900 dark:text-white" },
                                  "text": "{{$localized(bank.bank_name) || bank.bank_code}}"
                                },
                                {
                                  "type": "basic",
                                  "name": "P",
                                  "props": { "className": "text-sm text-gray-600 dark:text-gray-400" },
                                  "text": "{{bank.account_number}} ({{bank.account_holder}})"
                                }
                              ]
                            },
                            {
                              "type": "basic",
                              "name": "Icon",
                              "if": "{{_local.selectedDbank?.bank_code === bank.bank_code}}",
                              "props": { "name": "check-circle", "className": "w-5 h-5 text-blue-500" }
                            }
                          ]
                        }
                      ],
                      "actions": [
                        {
                          "type": "click",
                          "handler": "setState",
                          "params": { "target": "_local.selectedDbank", "value": "{{bank}}" }
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "type": "basic",
              "name": "Span",
              "if": "{{_local.errors?.['dbank.bank_code']}}",
              "props": { "className": "text-red-500 text-xs mt-1 block" },
              "text": "{{_local.errors?.['dbank.bank_code']?.[0] ?? ''}}"
            }
          ]
        },
        {
          "comment": "입금자명 입력",
          "type": "basic",
          "name": "Div",
          "props": { "className": "mt-4" },
          "responsive": {
            "portable": {
              "props": { "className": "mt-3" }
            }
          },
          "children": [
            {
              "type": "basic",
              "name": "Label",
              "props": { "className": "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" },
              "children": [
                { "type": "basic", "name": "Span", "text": "$t:shop.checkout.depositor_name" },
                { "type": "basic", "name": "Span", "props": { "className": "text-red-500 ml-1" }, "text": "*" }
              ]
            },
            {
              "type": "basic",
              "name": "Input",
              "props": {
                "type": "text",
                "name": "depositor_name",
                "value": "{{_local.depositorName ?? _computed.ordererDefaults?.name ?? ''}}",
                "placeholder": "$t:shop.checkout.depositor_name_placeholder",
                "className": "{{_local.errors?.depositor_name ? 'w-full px-4 py-2 border-2 border-red-500 rounded-lg bg-base-100 text-gray-900 dark:text-white focus:ring-2 focus:ring-red-500' : 'w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-base-100 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500'}}"
              },
              "responsive": {
                "portable": {
                  "props": {
                    "className": "{{_local.errors?.depositor_name ? 'w-full px-3 py-2 border-2 border-red-500 rounded-lg bg-base-100 text-gray-900 dark:text-white focus:ring-2 focus:ring-red-500 text-sm' : 'w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-base-100 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 text-sm'}}"
                  }
                }
              },
              "actions": [
                {
                  "type": "change",
                  "handler": "setState",
                  "params": { "target": "local", "depositorName": "{{$event.target.value}}" }
                }
              ]
            },
            {
              "type": "basic",
              "name": "Span",
              "if": "{{_local.errors?.depositor_name}}",
              "props": { "className": "text-red-500 text-xs mt-1 block" },
              "text": "{{_local.errors?.depositor_name?.[0] ?? ''}}"
            }
          ]
        },
        {
          "comment": "입금 기한 안내",
          "type": "basic",
          "name": "P",
          "props": { "className": "text-xs text-amber-600 dark:text-amber-400 mt-3" },
          "text": "$t:shop.checkout.dbank_due_notice|days={{paymentSettings.data?.order_settings?.dbank_due_days ?? 7}}"
        }
      ]
    }
  ]
}
