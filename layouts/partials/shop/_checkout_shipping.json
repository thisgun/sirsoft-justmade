                    "placeholder": "$t:shop.checkout.intl_city_placeholder",
                    "className": "{{_local.errors?.['shipping.intl_city'] ? 'w-full px-4 py-2 border-2 border-red-500 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-red-500' : 'w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500'}}"
                  },
                  "responsive": {
                    "portable": {
                      "props": {
                        "className": "{{_local.errors?.['shipping.intl_city'] ? 'w-full px-3 py-2 border-2 border-red-500 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-red-500 text-sm' : 'w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 text-sm'}}"
                      }
                    }
                  },
                  "actions": [
                    {
                      "type": "change",
                      "handler": "setState",
                      "params": { "target": "local", "shipping.intl_city": "{{$event.target.value}}" }
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "if": "{{_local.errors?.['shipping.intl_city']}}",
                  "props": { "className": "text-red-500 text-xs mt-1 block" },
                  "text": "{{_local.errors?.['shipping.intl_city']?.[0] ?? ''}}"
                }
              ]
            },
            {
              "type": "basic",
              "name": "Div",
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": { "className": "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" },
                  "text": "$t:shop.checkout.intl_state"
                },
                {
                  "type": "basic",
                  "name": "Input",
                  "props": {
                    "type": "text",
                    "name": "intl_state",
                    "value": "{{_local.shipping?.intl_state ?? ''}}",
                    "placeholder": "$t:shop.checkout.intl_state_placeholder",
                    "className": "w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500"
                  },
                  "responsive": {
                    "portable": {
                      "props": {
                        "className": "w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 text-sm"
                      }
                    }
                  },
                  "actions": [
                    {
                      "type": "change",
                      "handler": "setState",
                      "params": { "target": "local", "shipping.intl_state": "{{$event.target.value}}" }
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "comment": "Postal Code",
          "type": "basic",
          "name": "Div",
          "children": [
            {
              "type": "basic",
              "name": "Label",
              "props": { "className": "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" },
              "children": [
                { "type": "basic", "name": "Span", "text": "$t:shop.checkout.intl_postal_code" },
                { "type": "basic", "name": "Span", "props": { "className": "text-red-500 ml-1" }, "text": "*" }
              ]
            },
            {
              "type": "basic",
              "name": "Input",
              "props": {
                "type": "text",
                "name": "intl_postal_code",
                "value": "{{_local.shipping?.intl_postal_code ?? ''}}",
                "placeholder": "$t:shop.checkout.intl_postal_code_placeholder",
                "className": "{{_local.errors?.['shipping.intl_postal_code'] ? 'w-48 px-4 py-2 border-2 border-red-500 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-red-500' : 'w-48 px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500'}}"
              },
              "responsive": {
                "portable": {
                  "props": {
                    "className": "{{_local.errors?.['shipping.intl_postal_code'] ? 'w-full px-3 py-2 border-2 border-red-500 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-red-500 text-sm' : 'w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 text-sm'}}"
                  }
                }
              },
              "actions": [
                {
                  "type": "change",
                  "handler": "setState",
                  "params": { "target": "local", "shipping.intl_postal_code": "{{$event.target.value}}" }
                }
              ]
            },
            {
              "type": "basic",
              "name": "Span",
              "if": "{{_local.errors?.['shipping.intl_postal_code']}}",
              "props": { "className": "text-red-500 text-xs mt-1 block" },
              "text": "{{_local.errors?.['shipping.intl_postal_code']?.[0] ?? ''}}"
            }
          ]
        }
      ]
    },
    {
      "comment": "배송 메모",
      "type": "basic",
      "name": "Div",
      "props": { "className": "mb-4" },
      "responsive": {
        "portable": {
          "props": { "className": "mb-3" }
        }
      },
      "children": [
        {
          "type": "basic",
          "name": "Label",
          "props": { "className": "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1" },
          "text": "$t:shop.checkout.shipping_memo"
        },
        {
          "type": "basic",
          "name": "Select",
          "props": {
            "name": "shipping_memo",
            "value": "{{_local.shippingMemo ?? ''}}",
            "className": "w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500"
          },
          "responsive": {
            "portable": {
              "props": {
                "className": "w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 text-sm"
              }
            }
          },
          "children": [
            { "type": "basic", "name": "Option", "props": { "value": "" }, "text": "$t:shop.checkout.memo_none" },
            { "type": "basic", "name": "Option", "props": { "value": "door" }, "text": "$t:shop.checkout.memo_door" },
            { "type": "basic", "name": "Option", "props": { "value": "security" }, "text": "$t:shop.checkout.memo_security" },
            { "type": "basic", "name": "Option", "props": { "value": "parcel_box" }, "text": "$t:shop.checkout.memo_parcel_box" },
            { "type": "basic", "name": "Option", "props": { "value": "call" }, "text": "$t:shop.checkout.memo_call" },
            { "type": "basic", "name": "Option", "props": { "value": "custom" }, "text": "$t:shop.checkout.memo_custom" }
          ],
          "actions": [
            {
              "type": "change",
              "handler": "setState",
              "params": { "target": "local", "shippingMemo": "{{$event.target.value}}" }
            }
          ]
        }
      ]
    },
    {
      "comment": "직접 입력 (custom 선택 시)",
      "type": "basic",
      "name": "Div",
      "if": "{{_local.shippingMemo === 'custom'}}",
      "props": { "className": "mb-4" },
      "responsive": {
        "portable": {
          "props": { "className": "mb-3" }
        }
      },
      "children": [
        {
          "type": "basic",
          "name": "Input",
          "props": {
            "type": "text",
            "name": "shipping_memo_custom",
            "value": "{{_local.shippingMemoCustom ?? ''}}",
            "placeholder": "$t:shop.checkout.memo_custom_placeholder",
            "className": "w-full px-4 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500"
          },
          "responsive": {
            "portable": {
              "props": {
                "className": "w-full px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-blue-500 text-sm"
              }
            }
          },
          "actions": [
            {
              "type": "change",
              "handler": "setState",
              "params": { "target": "local", "shippingMemoCustom": "{{$event.target.value}}" }
            }
          ]
        }
      ]
    },
    {
      "comment": "배송지 저장 체크박스 (로그인 + 직접 입력한 경우만)",
      "type": "basic",
      "name": "Div",
      "if": "{{_global.currentUser != null && _local.selectedAddressId == null}}",
      "props": { "className": "flex items-center gap-2 mt-4" },
      "responsive": {
        "portable": {
          "props": { "className": "flex items-center gap-2 mt-3" }
        }
      },
      "children": [
        {
          "type": "basic",
          "name": "Checkbox",
          "props": {
            "id": "save_shipping_address",
            "name": "save_shipping_address",
            "checked": "{{_local.saveShippingAddress ?? false}}"
          },
          "actions": [
            {
              "type": "change",
              "handler": "setState",
              "params": { "target": "local", "saveShippingAddress": "{{$event.target.checked}}" }
            }
          ]
        },
        {
          "type": "basic",
          "name": "Label",
          "props": {
            "htmlFor": "save_shipping_address",
            "className": "text-sm text-gray-700 dark:text-gray-300 cursor-pointer select-none"
          },
          "text": "$t:shop.checkout.save_shipping_address_checkbox"
        }
      ]
    }
  ]
}
