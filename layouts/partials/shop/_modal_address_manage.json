{
  "meta": {
    "is_partial": true,
    "description": "체크아웃 배송지 관리 모달 - 배송지 선택, 추가, 삭제"
  },
  "type": "composite",
  "name": "Modal",
  "id": "addressManageModal",
  "props": {
    "title": "{{_local.addressModalMode === 'form' ? (_local.editingAddress ? '$t:shop.checkout.address_edit' : '$t:shop.checkout.address_add') : '$t:shop.checkout.address_manage'}}",
    "size": "lg"
  },
  "children": [
    {
      "comment": "배송지 목록 모드",
      "type": "basic",
      "name": "Div",
      "if": "{{_local.addressModalMode !== 'form'}}",
      "children": [
        {
          "comment": "목록 헤더 - 새 배송지 추가 버튼",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "flex justify-between items-center mb-4"
          },
          "children": [
            {
              "type": "basic",
              "name": "Span",
              "props": {
                "className": "text-sm text-gray-600 dark:text-gray-400"
              },
              "text": "$t:shop.checkout.saved_addresses"
            },
            {
              "type": "basic",
              "name": "Button",
              "props": {
                "type": "button",
                "className": "inline-flex items-center gap-1 px-3 py-1.5 text-sm text-gray-700 dark:text-gray-300 border border-gray-300 dark:border-gray-600 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors"
              },
              "children": [
                {
                  "type": "composite",
                  "name": "Icon",
                  "props": {
                    "name": "plus",
                    "size": "sm"
                  }
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "text": "$t:shop.checkout.address_add_new"
                }
              ],
              "actions": [
                {
                  "type": "click",
                  "handler": "setState",
                  "params": {
                    "target": "local",
                    "addressModalMode": "form",
                    "editingAddress": null,
                    "addressErrors": null
                  }
                }
              ]
            }
          ]
        },
        {
          "comment": "배송지 목록",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "space-y-3 max-h-96 overflow-y-auto"
          },
          "children": [
            {
              "comment": "배송지 없음",
              "type": "basic",
              "name": "Div",
              "if": "{{!(userAddresses?.data?.addresses?.data ?? []).length}}",
              "props": {
                "className": "text-center py-8 text-gray-500 dark:text-gray-400"
              },
              "children": [
                {
                  "type": "composite",
                  "name": "Icon",
                  "props": {
                    "name": "map-marker-alt",
                    "size": "2xl",
                    "className": "text-gray-300 dark:text-gray-600 mb-2"
                  }
                },
                {
                  "type": "basic",
                  "name": "P",
                  "text": "$t:shop.checkout.no_saved_addresses"
                }
              ]
            },
            {
              "comment": "배송지 목록 아이템",
              "type": "basic",
              "name": "Div",
              "iteration": {
                "source": "{{userAddresses?.data?.addresses?.data ?? []}}",
                "item_var": "addr",
                "index_var": "addrIdx"
              },
              "props": {
                "className": "border border-gray-200 dark:border-gray-700 rounded-lg p-4 hover:border-gray-400 dark:hover:border-gray-500 transition-colors cursor-pointer {{_local.selectedAddressId === addr.id ? 'ring-2 ring-gray-900 dark:ring-white border-transparent' : ''}}"
              },
              "actions": [
                {
                  "type": "click",
                  "handler": "setState",
                  "params": {
                    "target": "local",
                    "selectedAddressId": "{{addr.id}}",
                    "selectedAddressObj": "{{addr}}"
                  }
                }
              ],
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex justify-between items-start"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "flex-1"
                      },
                      "children": [
                        {
                          "comment": "배송지명 + 기본 배송지 뱃지",
                          "type": "basic",
                          "name": "Div",
                          "props": {
                            "className": "flex items-center gap-2 mb-1"
                          },
                          "children": [
                            {
                              "type": "basic",
                              "name": "Span",
                              "props": {
                                "className": "font-medium text-gray-900 dark:text-white"
                              },
                              "text": "{{$localized(addr.name)}}"
                            },
                            {
                              "type": "basic",
                              "name": "Span",
                              "if": "{{addr.is_default}}",
                              "props": {
                                "className": "px-2 py-0.5 text-xs bg-gray-900 dark:bg-white text-white dark:text-gray-900 rounded"
                              },
                              "text": "$t:shop.checkout.default_address"
                            }
                          ]
                        },
                        {
                          "comment": "받는 분 + 연락처",
                          "type": "basic",
                          "name": "Div",
                          "props": {
                            "className": "text-sm text-gray-600 dark:text-gray-400 mb-1"
                          },
                          "children": [
                            {
                              "type": "basic",
                              "name": "Span",
                              "text": "{{addr.recipient_name}}"
                            },
                            {
                              "type": "basic",
                              "name": "Span",
                              "props": {
                                "className": "mx-2"
                              },
                              "text": "|"
                            },
                            {
                              "type": "basic",
                              "name": "Span",
                              "text": "{{addr.recipient_phone}}"
                            }
                          ]
                        },
                        {
                          "comment": "주소",
                          "type": "basic",
                          "name": "Div",
                          "props": {
                            "className": "text-sm text-gray-600 dark:text-gray-400"
                          },
                          "children": [
                            {
                              "type": "basic",
                              "name": "Span",
                              "props": {
                                "className": "text-gray-500 dark:text-gray-500 mr-1"
                              },
                              "text": "({{addr.zipcode}})"
                            },
                            {
                              "type": "basic",
                              "name": "Span",
                              "text": "{{addr.address}} {{addr.address_detail ?? ''}}"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "comment": "선택 체크 아이콘",
                      "type": "basic",
                      "name": "Div",
                      "if": "{{_local.selectedAddressId === addr.id}}",
                      "props": {
                        "className": "flex-shrink-0 ml-2"
                      },
                      "children": [
                        {
                          "type": "composite",
                          "name": "Icon",
                          "props": {
                            "name": "check-circle",
                            "variant": "solid",
                            "className": "text-gray-900 dark:text-white text-xl"
                          }
                        }
                      ]
                    }
                  ]
                },
                {
                  "comment": "수정/삭제 버튼",
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "flex gap-2 mt-3 pt-3 border-t border-gray-100 dark:border-gray-700"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Button",
                      "props": {
                        "type": "button",
                        "className": "text-sm text-gray-600 dark:text-gray-400 hover:text-gray-900 dark:hover:text-white"
                      },
                      "text": "$t:common.edit",
                      "actions": [
                        {
                          "type": "click",
                          "handler": "stopPropagation"
                        },
                        {
                          "type": "click",
                          "handler": "setState",
                          "params": {
                            "target": "local",
                            "editingAddress": "{{addr}}",
                            "addressModalMode": "form",
                            "addressErrors": null
                          }
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Button",
                      "if": "{{!addr.is_default}}",
                      "props": {
                        "type": "button",
                        "className": "text-sm text-red-600 dark:text-red-400 hover:text-red-700 dark:hover:text-red-300"
                      },
                      "text": "$t:common.delete",
                      "actions": [
                        {
                          "type": "click",
                          "handler": "stopPropagation"
                        },
                        {
                          "type": "click",
                          "handler": "confirm",
                          "params": {
                            "message": "$t:shop.checkout.address_delete_confirm"
                          },
                          "onSuccess": [
                            {
                              "handler": "apiCall",
                              "target": "/api/modules/sirsoft-ecommerce/user/addresses/{{addr.id}}",
                              "params": {
                                "method": "DELETE"
                              },
                              "onSuccess": [
                                {
                                  "handler": "refetchDataSource",
                                  "params": {
                                    "dataSourceId": "userAddresses"
                                  }
                                },
                                {
                                  "handler": "toast",
                                  "params": {
                                    "type": "success",
                                    "message": "$t:shop.checkout.address_deleted"
                                  }
                                }
                              ],
                              "onError": [
                                {
                                  "handler": "toast",
                                  "params": {
                                    "type": "error",
                                    "message": "{{error.message}}"
                                  }
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "comment": "하단 버튼",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "flex justify-end gap-2 mt-6 pt-4 border-t border-gray-200 dark:border-gray-700"
          },
          "children": [
            {
              "type": "basic",
              "name": "Button",
              "props": {
                "type": "button",
                "className": "px-4 py-2 border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors"
              },
              "text": "$t:common.cancel",
              "actions": [
                {
                  "type": "click",
                  "handler": "closeModal"
                }
              ]
            },
            {
              "type": "basic",
              "name": "Button",
              "props": {
                "type": "button",
                "disabled": "{{!_local.selectedAddressId}}",
                "className": "px-4 py-2 bg-gray-900 dark:bg-white text-white dark:text-gray-900 rounded-lg font-medium hover:bg-gray-800 dark:hover:bg-gray-100 transition-colors disabled:opacity-50 disabled:cursor-not-allowed"
              },
              "text": "$t:shop.checkout.select_address",
              "actions": [
                {
                  "type": "click",
                  "handler": "sequence",
                  "actions": [
                    {
                      "comment": "부모 _local.shipping에 선택된 배송지 매핑 (모달 → 부모 상태 수정)",
                      "handler": "setState",
                      "params": {
                        "target": "$parent._local",
                        "selectedAddressId": "{{_local.selectedAddressId}}",
                        "selectedAddressObj": "{{_local.selectedAddressObj}}",
                        "shipping": {
                          "recipient_name": "{{_local.selectedAddressObj.recipient_name}}",
                          "recipient_phone": "{{_local.selectedAddressObj.recipient_phone}}",
                          "zipcode": "{{_local.selectedAddressObj.zipcode}}",
                          "address": "{{_local.selectedAddressObj.address}}",
                          "address_detail": "{{_local.selectedAddressObj.address_detail ?? ''}}",
                          "region": "{{_local.selectedAddressObj.region ?? ''}}",
                          "city": "{{_local.selectedAddressObj.city ?? ''}}",
                          "country_code": "{{_local.selectedAddressObj.country_code ?? 'KR'}}"
                        }
                      }
                    },
                    {
                      "comment": "부모 checkout.zipcode, country_code 업데이트 (도서산간 배송비 계산용)",
                      "handler": "setState",
                      "params": {
                        "target": "$parent._local",
                        "checkout.zipcode": "{{_local.selectedAddressObj.zipcode}}",
                        "checkout.country_code": "{{_local.selectedAddressObj.country_code ?? 'KR'}}"
                      }
                    },
                    {
                      "comment": "배송지 변경 시 checkout API 호출 (배송비 재계산)",
                      "handler": "apiCall",
                      "target": "/api/modules/sirsoft-ecommerce/checkout",
                      "auth_mode": "optional",
                      "params": {
                        "method": "PUT",
                        "body": "{{$parent._local.checkout}}"
                      },
                      "onSuccess": [
                        {
                          "handler": "updateDataSource",
                          "params": { "dataSourceId": "checkoutData", "data": "{{response}}" }
                        }
                      ]
                    },
                    {
                      "handler": "closeModal"
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "comment": "배송지 추가/수정 폼 모드",
      "type": "basic",
      "name": "Div",
      "if": "{{_local.addressModalMode === 'form'}}",
      "children": [
        {
          "type": "basic",
          "name": "Form",
          "dataKey": "editingAddress",
          "props": {
            "className": "space-y-4"
          },
          "children": [
            {
              "comment": "배송지명",
              "type": "basic",
              "name": "Div",
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Span",
                      "text": "$t:mypage.addresses.form.label"
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "text-red-500 ml-0.5"
                      },
                      "text": "*"
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Input",
                  "props": {
                    "type": "text",
                    "name": "name",
                    "placeholder": "$t:mypage.addresses.form.label_placeholder",
                    "required": true,
                    "className": "{{_local.addressErrors?.name ? 'w-full px-4 py-2.5 border-2 border-red-500 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-red-500 transition-colors' : 'w-full px-4 py-2.5 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-gray-900 dark:focus:ring-white focus:border-transparent transition-colors'}}"
                  }
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "if": "{{_local.addressErrors?.name}}",
                  "props": {
                    "className": "text-red-500 text-xs mt-1"
                  },
                  "text": "{{_local.addressErrors?.name?.[0] ?? ''}}"
                }
              ]
            },
            {
              "comment": "받는 분 + 연락처",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "grid grid-cols-2 gap-4"
              },
              "responsive": {
                "portable": {
                  "props": {
                    "className": "grid grid-cols-1 gap-3"
                  }
                }
              },
              "children": [
                {
                  "comment": "받는 분",
                  "type": "basic",
                  "name": "Div",
                  "children": [
                    {
                      "type": "basic",
                      "name": "Label",
                      "props": {
                        "className": "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Span",
                          "text": "$t:mypage.addresses.form.recipient"
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "text-red-500 ml-0.5"
                          },
                          "text": "*"
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Input",
                      "props": {
                        "type": "text",
                        "name": "recipient_name",
                        "placeholder": "$t:mypage.addresses.form.recipient_placeholder",
                        "required": true,
                        "className": "{{_local.addressErrors?.recipient_name ? 'w-full px-4 py-2.5 border-2 border-red-500 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-red-500 transition-colors' : 'w-full px-4 py-2.5 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-gray-900 dark:focus:ring-white focus:border-transparent transition-colors'}}"
                      }
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "if": "{{_local.addressErrors?.recipient_name}}",
                      "props": {
                        "className": "text-red-500 text-xs mt-1"
                      },
                      "text": "{{_local.addressErrors?.recipient_name?.[0] ?? ''}}"
                    }
                  ]
                },
                {
                  "comment": "연락처",
                  "type": "basic",
                  "name": "Div",
                  "children": [
                    {
                      "type": "basic",
                      "name": "Label",
                      "props": {
                        "className": "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Span",
                          "text": "$t:mypage.addresses.form.phone"
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": {
                            "className": "text-red-500 ml-0.5"
                          },
                          "text": "*"
                        }
                      ]
                    },
                    {
                      "type": "basic",
                      "name": "Input",
                      "props": {
                        "type": "tel",
                        "name": "recipient_phone",
                        "placeholder": "$t:mypage.addresses.form.phone_placeholder",
                        "required": true,
                        "className": "{{_local.addressErrors?.recipient_phone ? 'w-full px-4 py-2.5 border-2 border-red-500 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-red-500 transition-colors' : 'w-full px-4 py-2.5 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-gray-900 dark:focus:ring-white focus:border-transparent transition-colors'}}"
                      }
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "if": "{{_local.addressErrors?.recipient_phone}}",
                      "props": {
                        "className": "text-red-500 text-xs mt-1"
                      },
                      "text": "{{_local.addressErrors?.recipient_phone?.[0] ?? ''}}"
                    }
                  ]
                }
              ]
            },
            {
              "comment": "주소 검색",
              "type": "basic",
              "name": "Div",
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1"
                  },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Span",
                      "text": "$t:mypage.addresses.form.address"
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "props": {
                        "className": "text-red-500 ml-0.5"
                      },
                      "text": "*"
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Div",
                  "props": {
                    "className": "space-y-2"
                  },
                  "children": [
                    {
                      "comment": "우편번호 + 검색 버튼",
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "flex gap-2"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Input",
                          "props": {
                            "type": "text",
                            "name": "zipcode",
                            "placeholder": "$t:shop.checkout.zipcode_placeholder",
                            "className": "{{_local.addressErrors?.zipcode ? 'w-28 px-3 py-2 border-2 border-red-500 rounded-lg bg-gray-50 dark:bg-gray-700 text-gray-900 dark:text-white text-sm' : 'w-28 px-3 py-2 border border-gray-300 dark:border-gray-600 rounded-lg bg-gray-50 dark:bg-gray-700 text-gray-900 dark:text-white text-sm'}}",
                            "readOnly": true
                          }
                        },
                        {
                          "id": "checkout_modal_address_search_slot",
                          "type": "extension_point",
                          "name": "address_search_slot",
                          "props": {
                            "readOnlyFields": ["zipcode", "address"],
                            "onAddressSelect": {
                              "handler": "setState",
                              "params": {
                                "target": "local",
                                "editingAddress.zipcode": "{{$event.zipcode}}",
                                "editingAddress.address": "{{$event.address}}",
                                "editingAddress.region": "{{$event.region}}",
                                "editingAddress.city": "{{$event.city}}"
                              }
                            }
                          }
                        }
                      ]
                    },
                    {
                      "comment": "기본 주소",
                      "type": "basic",
                      "name": "Input",
                      "props": {
                        "type": "text",
                        "name": "address",
                        "placeholder": "$t:shop.checkout.address_placeholder",
                        "className": "{{_local.addressErrors?.address ? 'w-full px-4 py-2.5 border-2 border-red-500 rounded-lg bg-gray-50 dark:bg-gray-700 text-gray-900 dark:text-white text-sm' : 'w-full px-4 py-2.5 border border-gray-300 dark:border-gray-600 rounded-lg bg-gray-50 dark:bg-gray-700 text-gray-900 dark:text-white text-sm'}}",
                        "readOnly": true
                      }
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "if": "{{_local.addressErrors?.zipcode || _local.addressErrors?.address}}",
                      "props": {
                        "className": "text-red-500 text-xs mt-1"
                      },
                      "text": "{{_local.addressErrors?.zipcode?.[0] ?? _local.addressErrors?.address?.[0] ?? ''}}"
                    }
                  ]
                }
              ]
            },
            {
              "comment": "상세 주소",
              "type": "basic",
              "name": "Div",
              "children": [
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1"
                  },
                  "text": "$t:mypage.addresses.form.detail_address"
                },
                {
                  "type": "basic",
                  "name": "Input",
                  "props": {
                    "type": "text",
                    "name": "address_detail",
                    "placeholder": "$t:mypage.addresses.form.detail_placeholder",
                    "className": "{{_local.addressErrors?.address_detail ? 'w-full px-4 py-2.5 border-2 border-red-500 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-red-500 transition-colors' : 'w-full px-4 py-2.5 border border-gray-300 dark:border-gray-600 rounded-lg bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-2 focus:ring-gray-900 dark:focus:ring-white focus:border-transparent transition-colors'}}"
                  }
                }
              ]
            },
            {
              "comment": "기본 배송지 체크박스",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex items-center gap-2 pt-2"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Checkbox",
                  "props": {
                    "name": "is_default",
                    "className": "w-4 h-4 text-gray-900 dark:text-white border-gray-300 dark:border-gray-600 rounded focus:ring-gray-900 dark:focus:ring-white"
                  }
                },
                {
                  "type": "basic",
                  "name": "Label",
                  "props": {
                    "className": "text-sm text-gray-700 dark:text-gray-300 cursor-pointer"
                  },
                  "text": "$t:mypage.addresses.form.set_default"
                }
              ]
            },
            {
              "comment": "하단 버튼",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "flex justify-end gap-2 mt-6 pt-4 border-t border-gray-200 dark:border-gray-700"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Button",
                  "props": {
                    "type": "button",
                    "className": "px-4 py-2 border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 rounded-lg hover:bg-gray-50 dark:hover:bg-gray-700 transition-colors"
                  },
                  "text": "$t:common.back",
                  "actions": [
                    {
                      "type": "click",
                      "handler": "setState",
                      "params": {
                        "target": "local",
                        "addressModalMode": "list",
                        "editingAddress": null,
                        "addressErrors": null
                      }
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Button",
                  "props": {
                    "type": "button",
                    "className": "px-4 py-2 bg-gray-900 dark:bg-white text-white dark:text-gray-900 rounded-lg font-medium hover:bg-gray-800 dark:hover:bg-gray-100 transition-colors disabled:opacity-50 disabled:cursor-not-allowed flex items-center justify-center gap-2",
                    "disabled": "{{_local.isSaving ?? false}}"
                  },
                  "children": [
                    {
                      "comment": "스피너",
                      "type": "basic",
                      "name": "Div",
                      "if": "{{_local.isSaving}}",
                      "props": {
                        "className": "w-4 h-4 border-2 border-white/30 dark:border-gray-900/30 border-t-white dark:border-t-gray-900 rounded-full animate-spin"
                      }
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "if": "{{!_local.isSaving}}",
                      "text": "{{_local.editingAddress?.id ? '$t:common.save' : '$t:mypage.addresses.add'}}"
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "if": "{{_local.isSaving}}",
                      "text": "$t:common.processing"
                    }
                  ],
                  "actions": [
                    {
                      "type": "click",
                      "handler": "sequence",
                      "actions": [
                        {
                          "handler": "setState",
                          "params": {
                            "target": "local",
                            "isSaving": true,
                            "addressErrors": null
                          }
                        },
                        {
                          "handler": "apiCall",
                          "auth_required": true,
                          "target": "{{_local.editingAddress?.id ? '/api/modules/sirsoft-ecommerce/user/addresses/' + _local.editingAddress.id : '/api/modules/sirsoft-ecommerce/user/addresses'}}",
                          "params": {
                            "method": "{{_local.editingAddress?.id ? 'PUT' : 'POST'}}",
                            "body": "{{_local.editingAddress}}"
                          },
                          "onSuccess": [
                            {
                              "handler": "refetchDataSource",
                              "params": {
                                "dataSourceId": "userAddresses"
                              }
                            },
                            {
                              "handler": "setState",
                              "params": {
                                "target": "local",
                                "isSaving": false,
                                "addressModalMode": "list",
                                "editingAddress": null,
                                "addressErrors": null
                              }
                            },
                            {
                              "handler": "toast",
                              "params": {
                                "type": "success",
                                "message": "{{_local.editingAddress?.id ? '$t:mypage.addresses.updated' : '$t:mypage.addresses.added'}}"
                              }
                            }
                          ],
                          "onError": [
                            {
                              "handler": "setState",
                              "params": {
                                "target": "local",
                                "isSaving": false,
                                "addressErrors": "{{error.errors ?? {}}}"
                              }
                            },
                            {
                              "handler": "toast",
                              "params": {
                                "type": "error",
                                "message": "{{error.message}}"
                              }
                            }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
