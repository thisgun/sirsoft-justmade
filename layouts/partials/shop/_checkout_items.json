{
  "meta": {
    "is_partial": true,
    "description": "주문 상품 목록 섹션 (PC/모바일 반응형)"
  },
  "type": "basic",
  "name": "Div",
  "props": { "className": "card bg-base-100 shadow-sm p-6" },
  "responsive": {
    "portable": {
      "props": { "className": "card bg-base-100 shadow-sm p-4" }
    }
  },
  "children": [
    {
      "comment": "섹션 헤더",
      "type": "basic",
      "name": "Div",
      "props": { "className": "flex items-center gap-2 mb-4 pb-4 border-b border-gray-200 dark:border-gray-700" },
      "responsive": {
        "portable": {
          "props": { "className": "flex items-center gap-2 mb-3 pb-3 border-b border-gray-200 dark:border-gray-700" }
        }
      },
      "children": [
        { "type": "basic", "name": "Icon", "props": { "name": "shopping-cart", "className": "w-5 h-5 text-gray-700 dark:text-gray-300" } },
        {
          "type": "basic",
          "name": "H2",
          "props": { "className": "text-lg font-semibold text-gray-900 dark:text-white" },
          "responsive": {
            "portable": {
              "props": { "className": "text-base font-semibold text-gray-900 dark:text-white" }
            }
          },
          "text": "$t:shop.checkout.order_items"
        }
      ]
    },
    {
      "comment": "상품 목록",
      "type": "basic",
      "name": "Div",
      "props": { "className": "divide-y divide-gray-200 dark:divide-gray-700" },
      "children": [
        {
          "type": "basic",
          "name": "Div",
          "iteration": { "source": "{{checkoutData.data.items ?? []}}", "item_var": "item" },
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": { "className": "flex gap-4 py-4" },
              "responsive": {
                "portable": {
                  "props": { "className": "flex gap-3 py-3" }
                }
              },
              "children": [
                {
                  "comment": "상품 이미지 (새 창으로 열기)",
                  "type": "basic",
                  "name": "A",
                  "props": { "href": "{{_global.shopBase}}/products/{{item.product_id}}", "target": "_blank", "className": "flex-shrink-0" },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Div",
                      "props": { "className": "w-20 h-20 rounded-lg overflow-hidden bg-gray-100 dark:bg-gray-700" },
                      "responsive": {
                        "portable": {
                          "props": { "className": "w-16 h-16 rounded-lg overflow-hidden bg-gray-100 dark:bg-gray-700" }
                        }
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Img",
                          "props": {
                            "src": "{{item.product.thumbnail_url}}",
                            "alt": "{{item.product.name}}",
                            "className": "w-full h-full object-cover"
                          }
                        }
                      ]
                    }
                  ]
                },
                {
                  "comment": "상품 정보",
                  "type": "basic",
                  "name": "Div",
                  "props": { "className": "flex-1 min-w-0" },
                  "children": [
                    {
                      "comment": "상품명 (새 창으로 열기)",
                      "type": "basic",
                      "name": "A",
                      "props": { "href": "{{_global.shopBase}}/products/{{item.product_id}}", "target": "_blank", "className": "block no-underline" },
                      "children": [
                        {
                          "type": "basic",
                          "name": "H3",
                          "props": { "className": "text-sm font-medium text-gray-900 dark:text-white hover:text-blue-600 dark:hover:text-blue-400 truncate" },
                          "text": "{{item.product.name}}"
                        }
                      ]
                    },
                    {
                      "comment": "상품 옵션 값 (옵션이 있을 때만 표시)",
                      "type": "basic",
                      "name": "P",
                      "if": "{{item.product_option && Object.keys(item.product_option.option_values_localized ?? {}).length > 0}}",
                      "props": { "className": "text-sm text-gray-500 dark:text-gray-400 mt-1" },
                      "responsive": {
                        "portable": {
                          "props": { "className": "text-xs text-gray-500 dark:text-gray-400 mt-0.5" }
                        }
                      },
                      "text": "{{Object.entries(item.product_option?.option_values_localized ?? {}).map(([k, v]) => k + ': ' + v).join(', ')}}"
                    },
                    {
                      "comment": "배송정책 및 배송비",
                      "type": "basic",
                      "name": "Div",
                      "if": "{{checkoutData.data.calculation?.items?.find(ci => ci.product_option_id === item.product_option_id)?.applied_shipping_policy}}",
                      "props": { "className": "flex items-center gap-2 mt-1" },
                      "responsive": {
                        "portable": {
                          "props": { "className": "flex items-center gap-2 mt-0.5" }
                        }
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Icon",
                          "props": { "name": "truck", "size": "xs", "className": "text-gray-400 dark:text-gray-500" }
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": { "className": "text-xs text-gray-500 dark:text-gray-400" },
                          "text": "{{checkoutData.data.calculation?.items?.find(ci => ci.product_option_id === item.product_option_id)?.applied_shipping_policy?.policy_name}}"
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": { "className": "text-xs text-gray-400 dark:text-gray-500" },
                          "text": "/"
                        },
                        {
                          "comment": "단독 구매 시 배송비 > 0",
                          "type": "basic",
                          "name": "Span",
                          "if": "{{(checkoutData.data.calculation?.items?.find(ci => ci.product_option_id === item.product_option_id)?.applied_shipping_policy?.standalone_shipping_amount ?? 0) > 0}}",
                          "props": { "className": "text-xs text-gray-600 dark:text-gray-300" },
                          "text": "{{checkoutData.data.calculation?.items?.find(ci => ci.product_option_id === item.product_option_id)?.applied_shipping_policy?.standalone_shipping_amount_formatted ?? ''}}"
                        },
                        {
                          "comment": "단독 구매 시 무료배송",
                          "type": "basic",
                          "name": "Span",
                          "if": "{{(checkoutData.data.calculation?.items?.find(ci => ci.product_option_id === item.product_option_id)?.applied_shipping_policy?.standalone_shipping_amount ?? 0) === 0}}",
                          "props": { "className": "text-xs text-green-600 dark:text-green-400" },
                          "text": "$t:shop.checkout.free_shipping"
                        }
                      ]
                    },
                    {
                      "comment": "단가 - 주 통화",
                      "type": "basic",
                      "name": "P",
                      "props": { "className": "text-sm text-gray-600 dark:text-gray-400 mt-1" },
                      "responsive": {
                        "portable": {
                          "props": { "className": "text-xs text-gray-600 dark:text-gray-400 mt-0.5" }
                        }
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Span",
                          "text": "{{item.product_option?.multi_currency_selling_price?.[_global.preferredCurrency ?? 'KRW']?.formatted ?? item.product_option?.selling_price_formatted ?? ''}} × {{item.quantity}}"
                        },
                        {
                          "type": "basic",
                          "name": "Span",
                          "text": "$t:shop.count_unit"
                        }
                      ]
                    },
                    {
                      "comment": "단가 - 보조 통화들 (선택된 통화 제외)",
                      "type": "basic",
                      "name": "Div",
                      "props": { "className": "flex flex-wrap gap-x-2 mt-0.5" },
                      "iteration": {
                        "source": "{{Object.entries(item.product_option?.multi_currency_selling_price ?? {}).filter(([code]) => code !== (_global.preferredCurrency ?? 'KRW'))}}",
                        "item_var": "currency"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": { "className": "text-xs text-gray-500 dark:text-gray-400" },
                          "text": "{{currency[1]?.formatted}}"
                        }
                      ]
                    },
                    {
                      "comment": "상품 상태 표시 영역",
                      "type": "basic",
                      "name": "Div",
                      "if": "{{item.product.sales_status !== 'on_sale' || item.quantity > (item.product_option?.stock_quantity ?? 0)}}",
                      "props": { "className": "flex items-center gap-2 mt-1" },
                      "children": [
                        {
                          "comment": "판매중지 표시",
                          "type": "basic",
                          "name": "Span",
                          "if": "{{item.product.sales_status !== 'on_sale'}}",
                          "props": { "className": "text-sm font-medium text-red-600 dark:text-red-400" },
                          "text": "$t:shop.cart.not_on_sale"
                        },
                        {
                          "comment": "재고부족 표시 (판매중이지만 재고 부족)",
                          "type": "basic",
                          "name": "Span",
                          "if": "{{item.product.sales_status === 'on_sale' && item.quantity > (item.product_option?.stock_quantity ?? 0)}}",
                          "props": { "className": "text-sm font-medium text-red-600 dark:text-red-400" },
                          "text": "$t:shop.cart.insufficient_stock"
                        }
                      ]
                    },
                    {
                      "comment": "적용된 상품 쿠폰 상세 목록",
                      "type": "basic",
                      "name": "Div",
                      "if": "{{(item.product_coupon_discount_amount ?? 0) > 0}}",
                      "props": { "className": "mt-1 space-y-0.5" },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Div",
                          "iteration": {
                            "source": "{{(checkoutData.data.calculation?.promotions?.product_promotions?.coupons ?? []).filter(c => (c.applied_items ?? []).some(ai => ai.product_option_id === item.product_option_id))}}",
                            "item_var": "appliedCoupon"
                          },
                          "props": { "className": "flex items-center gap-1" },
                          "children": [
                            { "type": "basic", "name": "Icon", "props": { "name": "ticket", "className": "w-3 h-3 text-red-500 dark:text-red-400" } },
                            {
                              "type": "basic",
                              "name": "Span",
                              "props": { "className": "text-xs text-red-600 dark:text-red-400" },
                              "text": "{{appliedCoupon.name}} -{{appliedCoupon.applied_items?.find(ai => ai.product_option_id === item.product_option_id)?.discount_amount_formatted ?? ''}}"
                            }
                          ]
                        }
                      ]
                    },
                    {
                      "comment": "상품별 쿠폰 선택 영역 (회원만)",
                      "type": "basic",
                      "name": "Div",
                      "if": "{{_global.currentUser?.uuid}}",
                      "props": { "className": "mt-2 flex flex-wrap gap-2" },
                      "responsive": {
                        "portable": {
                          "props": { "className": "mt-1.5 flex flex-col gap-1.5" }
                        }
                      },
                      "children": [
                        {
                          "comment": "상품 쿠폰 1",
                          "type": "basic",
                          "name": "Select",
                          "props": {
                            "name": "item_coupon_1",
                            "value": "{{_local.checkout?.item_coupons?.[item.product_option_id]?.[0] ?? ''}}",
                            "className": "w-48 px-2 py-1 text-xs border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-1 focus:ring-blue-500"
                          },
                          "responsive": {
                            "portable": {
                              "props": {
                                "className": "w-full px-2 py-1.5 text-xs border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-1 focus:ring-blue-500"
                              }
                            }
                          },
                          "children": [
                            {
                              "type": "basic",
                              "name": "Option",
                              "props": { "value": "" },
                              "text": "{{(item.available_coupons ?? []).length > 0 ? '$t:shop.checkout.product_coupon_1' : '$t:shop.checkout.coupon_no_available'}}"
                            },
                            {
                              "type": "basic",
                              "name": "Option",
                              "iteration": {
                                "source": "{{item.available_coupons ?? []}}",
                                "item_var": "pcoupon"
                              },
                              "props": {
                                "value": "{{pcoupon.id}}",
                                "disabled": "{{_local.checkout?.item_coupons?.[item.product_option_id]?.[1] == pcoupon.id}}"
                              },
                              "text": "{{'[' + pcoupon.target_type_short_label + '] ' + pcoupon.localized_name + ' (' + pcoupon.benefit_formatted + ')'}}"
                            }
                          ],
                          "actions": [
                            {
                              "type": "change",
                              "handler": "sequence",
                              "actions": [
                                {
                                  "handler": "setState",
                                  "params": {
                                    "target": "local",
                                    "checkout": "{{Object.assign({}, _local.checkout, { item_coupons: Object.assign({}, _local.checkout?.item_coupons ?? {}, { [item.product_option_id]: [$event.target.value || null, (_local.checkout?.item_coupons?.[item.product_option_id]?.[1] ?? null)].filter(Boolean) }) })}}"
                                  }
                                },
                                {
                                  "handler": "apiCall",
                                  "target": "/api/modules/sirsoft-ecommerce/checkout",
                                  "auth_mode": "optional",
                                  "params": {
                                    "method": "PUT",
                                    "body": "{{_local.checkout}}"
                                  },
                                  "onSuccess": [
                                    {
                                      "handler": "updateDataSource",
                                      "params": { "dataSourceId": "checkoutData", "data": "{{response}}" }
                                    }
                                  ]
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "comment": "상품 쿠폰 2 (첫 번째 쿠폰 선택 시에만 표시)",
                          "type": "basic",
                          "name": "Select",
                          "if": "{{_local.checkout?.item_coupons?.[item.product_option_id]?.[0]}}",
                          "props": {
                            "name": "item_coupon_2",
                            "value": "{{_local.checkout?.item_coupons?.[item.product_option_id]?.[1] ?? ''}}",
                            "className": "w-48 px-2 py-1 text-xs border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-1 focus:ring-blue-500"
                          },
                          "responsive": {
                            "portable": {
                              "props": {
                                "className": "w-full px-2 py-1.5 text-xs border border-gray-300 dark:border-gray-600 rounded bg-white dark:bg-gray-700 text-gray-900 dark:text-white focus:ring-1 focus:ring-blue-500"
                              }
                            }
                          },
                          "children": [
                            {
                              "type": "basic",
                              "name": "Option",
                              "props": { "value": "" },
                              "text": "{{(item.available_coupons ?? []).length > 0 ? '$t:shop.checkout.product_coupon_2' : '$t:shop.checkout.coupon_no_available'}}"
                            },
                            {
                              "type": "basic",
                              "name": "Option",
                              "iteration": {
                                "source": "{{item.available_coupons ?? []}}",
                                "item_var": "pcoupon2"
                              },
                              "props": {
                                "value": "{{pcoupon2.id}}",
                                "disabled": "{{_local.checkout?.item_coupons?.[item.product_option_id]?.[0] == pcoupon2.id}}"
                              },
                              "text": "{{'[' + pcoupon2.target_type_short_label + '] ' + pcoupon2.localized_name + ' (' + pcoupon2.benefit_formatted + ')'}}"
                            }
                          ],
                          "actions": [
                            {
                              "type": "change",
                              "handler": "sequence",
                              "actions": [
                                {
                                  "handler": "setState",
                                  "params": {
                                    "target": "local",
                                    "checkout": "{{Object.assign({}, _local.checkout, { item_coupons: Object.assign({}, _local.checkout?.item_coupons ?? {}, { [item.product_option_id]: [(_local.checkout?.item_coupons?.[item.product_option_id]?.[0] ?? null), $event.target.value || null].filter(Boolean) }) })}}"
                                  }
                                },
                                {
                                  "handler": "apiCall",
                                  "target": "/api/modules/sirsoft-ecommerce/checkout",
                                  "auth_mode": "optional",
                                  "params": {
                                    "method": "PUT",
                                    "body": "{{_local.checkout}}"
                                  },
                                  "onSuccess": [
                                    {
                                      "handler": "updateDataSource",
                                      "params": { "dataSourceId": "checkoutData", "data": "{{response}}" }
                                    }
                                  ]
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                },
                {
                  "comment": "상품 금액",
                  "type": "basic",
                  "name": "Div",
                  "props": { "className": "flex flex-col items-end justify-start flex-shrink-0 ml-4" },
                  "responsive": {
                    "portable": {
                      "props": { "className": "flex flex-col items-end justify-start flex-shrink-0 ml-2" }
                    }
                  },
                  "children": [
                    {
                      "comment": "상품 금액 라벨",
                      "type": "basic",
                      "name": "Span",
                      "props": { "className": "text-xs text-gray-500 dark:text-gray-400" },
                      "text": "$t:shop.cart.subtotal"
                    },
                    {
                      "comment": "원 판매금액 (할인 없을 때) - 주 통화",
                      "type": "basic",
                      "name": "Div",
                      "if": "{{(item.product_coupon_discount_amount ?? 0) === 0}}",
                      "props": { "className": "font-bold text-gray-900 dark:text-white" },
                      "text": "{{item.multi_currency_subtotal?.[_global.preferredCurrency ?? 'KRW']?.formatted ?? item.subtotal_formatted}}"
                    },
                    {
                      "comment": "원 판매금액 (할인 있을 때 취소선) - 주 통화",
                      "type": "basic",
                      "name": "Div",
                      "if": "{{(item.product_coupon_discount_amount ?? 0) > 0}}",
                      "props": { "className": "text-sm text-gray-400 dark:text-gray-500 line-through" },
                      "text": "{{item.multi_currency_subtotal?.[_global.preferredCurrency ?? 'KRW']?.formatted ?? item.subtotal_formatted}}"
                    },
                    {
                      "comment": "할인 후 금액 - 주 통화",
                      "type": "basic",
                      "name": "Div",
                      "if": "{{(item.product_coupon_discount_amount ?? 0) > 0}}",
                      "props": { "className": "font-bold text-red-600 dark:text-red-400" },
                      "text": "{{item.multi_currency_final_amount?.[_global.preferredCurrency ?? 'KRW']?.formatted ?? item.final_amount_formatted}}"
                    },
                    {
                      "comment": "원 판매금액 - 보조 통화들 (할인 없을 때)",
                      "type": "basic",
                      "name": "Div",
                      "if": "{{(item.product_coupon_discount_amount ?? 0) === 0}}",
                      "props": { "className": "flex flex-wrap gap-x-2 justify-end" },
                      "iteration": {
                        "source": "{{Object.entries(item.multi_currency_subtotal ?? {}).filter(([code]) => code !== (_global.preferredCurrency ?? 'KRW'))}}",
                        "item_var": "subtotalCurrency"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": { "className": "text-xs text-gray-500 dark:text-gray-400" },
                          "text": "{{subtotalCurrency[1]?.formatted}}"
                        }
                      ]
                    },
                    {
                      "comment": "할인 후 금액 - 보조 통화들",
                      "type": "basic",
                      "name": "Div",
                      "if": "{{(item.product_coupon_discount_amount ?? 0) > 0}}",
                      "props": { "className": "flex flex-wrap gap-x-2 justify-end" },
                      "iteration": {
                        "source": "{{Object.entries(item.multi_currency_final_amount ?? {}).filter(([code]) => code !== (_global.preferredCurrency ?? 'KRW'))}}",
                        "item_var": "finalCurrency"
                      },
                      "children": [
                        {
                          "type": "basic",
                          "name": "Span",
                          "props": { "className": "text-xs text-red-500 dark:text-red-400" },
                          "text": "{{finalCurrency[1]?.formatted}}"
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
    }
  ]
}
