{
  "meta": {
    "is_partial": true,
    "description": "게시판 요약 카드 - 보더 없는 클린 스타일"
  },
  "type": "basic",
  "name": "Div",
  "props": {
    "className": "bg-base-100 rounded-2xl pt-5 hover:shadow-md transition-shadow"
  },
  "children": [
    {
      "type": "basic",
      "name": "Div",
      "props": { "className": "flex items-center justify-between mb-3 px-5" },
      "children": [
        {
          "type": "basic",
          "name": "Button",
          "props": { "className": "font-bold text-base-content hover:text-primary cursor-pointer transition-colors" },
          "text": "{{item.name}}",
          "actions": [{ "type": "click", "handler": "navigate", "params": { "path": "/board/{{item.slug}}" } }]
        },
        { "type": "basic", "name": "Span", "props": { "className": "text-xs font-medium text-primary/60 bg-primary/5 px-2.5 py-1 rounded-full" }, "text": "{{item.posts_count}}" }
      ]
    },
    {
      "type": "basic",
      "name": "Div",
      "props": { "className": "px-5 pb-3" },
      "children": [
        {
          "type": "basic",
          "name": "Div",
          "if": "{{item.recent_posts && item.recent_posts.length > 0}}",
          "props": { "className": "space-y-0.5" },
          "iteration": { "source": "{{item.recent_posts ?? []}}", "item_var": "post" },
          "children": [
            {
              "type": "basic",
              "name": "Div",
              "props": { "className": "flex items-center justify-between w-full hover:bg-base-200/50 rounded-lg py-2 px-1 transition-colors gap-2" },
              "children": [
                {
                  "type": "basic",
                  "name": "Div",
                  "props": { "className": "flex items-center gap-2 flex-1 min-w-0" },
                  "children": [
                    {
                      "type": "basic",
                      "name": "Span",
                      "if": "{{post.is_notice}}",
                      "props": { "className": "text-xs font-medium text-error px-1.5 py-0.5 rounded shrink-0 bg-error/5" },
                      "text": "$t:board.notice"
                    },
                    {
                      "type": "basic",
                      "name": "Button",
                      "props": { "className": "text-sm text-base-content text-left line-clamp-1 hover:text-primary cursor-pointer transition-colors" },
                      "actions": [{ "type": "click", "handler": "navigate", "params": { "path": "/board/{{item.slug}}/{{post.id}}" } }],
                      "text": "{{post.title}}"
                    },
                    {
                      "type": "basic",
                      "name": "Span",
                      "if": "{{post.comment_count > 0}}",
                      "props": { "className": "text-xs text-primary/50 shrink-0" },
                      "text": "[{{post.comment_count}}]"
                    }
                  ]
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "props": { "className": "text-xs text-base-content/30 shrink-0", "title": "{{post.created_at ?? ''}}" },
                  "text": "{{post.created_at_formatted ?? ''}}"
                }
              ]
            }
          ]
        },
        {
          "type": "basic",
          "name": "Div",
          "if": "{{!item.recent_posts || item.recent_posts.length === 0}}",
          "props": { "className": "py-8 text-center text-sm text-base-content/25" },
          "children": [
            { "type": "basic", "name": "Span", "text": "$t:home.no_posts" }
          ]
        }
      ]
    },
    {
      "comment": "=== 더보기 ===",
      "type": "basic",
      "name": "Button",
      "props": { "className": "w-full px-5 py-3 text-center text-xs font-medium text-base-content/35 hover:text-primary hover:bg-base-200/50 transition-colors cursor-pointer border-t border-base-content/5 rounded-b-2xl" },
      "actions": [{ "type": "click", "handler": "navigate", "params": { "path": "/board/{{item.slug}}" } }],
      "children": [
        { "type": "basic", "name": "Span", "text": "$t:common.more" },
        { "type": "basic", "name": "Icon", "props": { "name": "arrow-right", "className": "w-3.5 h-3.5 inline-block ml-1" } }
      ]
    }
  ]
}
