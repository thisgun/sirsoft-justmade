{
  "meta": {
    "is_partial": true,
    "description": "게시판 기본형(basic) 인덱스. 헤더 + 필터 + 테이블형 목록 + 빈상태 + 페이지네이션 + 글쓰기 버튼"
  },
  "type": "basic",
  "name": "Div",
  "children": [
    {
      "comment": "헤더 (게시판명 + 설명 + 글쓰기 버튼)",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "flex justify-between items-start mb-6"
      },
      "children": [
        {
          "type": "basic",
          "name": "Div",
          "children": [
            {
              "type": "basic",
              "name": "H1",
              "props": {
                "className": "text-2xl font-bold text-gray-900 dark:text-white"
              },
              "text": "{{posts?.data?.board?.name ?? ''}}"
            },
            {
              "type": "basic",
              "name": "P",
              "if": "{{posts?.data?.board?.description}}",
              "props": {
                "className": "text-gray-600 dark:text-gray-400 mt-1"
              },
              "text": "{{posts?.data?.board?.description}}"
            }
          ]
        },
        {
          "type": "basic",
          "name": "Div",
          "props": { "className": "flex items-center gap-2" },
          "children": [
            {
              "comment": "게시판관리 버튼 (관리자만, 새창)",
              "type": "basic",
              "name": "A",
              "if": "{{_global.currentUser?.is_admin}}",
              "props": {
                "href": "/admin/boards/{{board_detail?.data?.id}}/edit",
                "target": "_blank",
                "className": "inline-flex items-center gap-1.5 px-3 py-2 text-sm font-medium text-gray-700 dark:text-gray-300 bg-base-200 hover:bg-base-300 rounded-lg transition-colors no-underline cursor-pointer"
              },
              "children": [
                { "type": "composite", "name": "Icon", "props": { "name": "settings", "className": "w-4 h-4" } },
                { "type": "basic", "name": "Span", "text": "$t:common.admin_board_manage" }
              ]
            },
            {
              "comment": "상단 글쓰기 버튼",
              "partial": "../../index/_write_button.json"
            }
          ]
        }
      ]
    },
    {
      "comment": "필터 바 (카테고리 필터 + 검색)",
      "type": "basic",
      "name": "Div",
      "props": {
        "className": "flex flex-col sm:flex-row items-stretch sm:items-center justify-between gap-3 mb-4"
      },
      "children": [
        {
          "comment": "카테고리 필터 (카테고리가 있을 때만 표시)",
          "type": "basic",
          "name": "Select",
          "if": "{{posts?.data?.board?.categories && posts?.data?.board?.categories.length > 0}}",
          "props": {
            "value": "{{query.category || 'all'}}",
            "className": "w-full sm:w-auto sm:min-w-48 px-3 py-2 bg-base-100 border border-gray-300 dark:border-gray-600 rounded-lg text-gray-900 dark:text-white text-sm",
            "options": "{{[{value:'all', label:'$t:board.filter.category_all'},{value:'unclassified', label:'$t:board.filter.category_unclassified'}].concat((posts?.data?.board?.categories ?? []).map(function(c){return{value:c,label:c};}))}}"
          },
          "actions": [
            {
              "type": "change",
              "handler": "navigate",
              "params": {
                "path": "/board/{{route.slug}}",
                "mergeQuery": true,
                "query": {
                  "category": "{{$event.target.value === 'all' ? '' : $event.target.value}}",
                  "page": 1
                }
              }
            }
          ]
        },
        {
          "comment": "삭제된 게시글 포함 토글 버튼 (manager 권한 보유 시에만 표시)",
          "type": "basic",
          "name": "Button",
          "if": "{{posts?.data?.abilities?.can_view_deleted}}",
          "props": {
            "type": "button",
            "className": "{{query.del === '1' ? 'inline-flex items-center gap-1.5 px-3 py-2 border-2 border-blue-600 dark:border-blue-400 bg-blue-50 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 rounded-lg text-sm font-medium' : 'inline-flex items-center gap-1.5 px-3 py-2 border border-gray-300 dark:border-gray-600 text-gray-700 dark:text-gray-300 rounded-lg text-sm hover:bg-gray-50 dark:hover:bg-gray-700'}}"
          },
          "actions": [
            {
              "type": "click",
              "handler": "navigate",
              "params": {
                "path": "/board/{{route.slug}}",
                "mergeQuery": true,
                "query": {
                  "del": "{{query.del === '1' ? '' : '1'}}",
                  "page": 1
                }
              }
            }
          ],
          "children": [
            { "type": "basic", "name": "Icon", "props": { "name": "eye", "size": "sm" } },
            { "type": "basic", "name": "Span", "text": "$t:board.filter.include_deleted" }
          ]
        },
        {
          "comment": "검색 바 (오른쪽 정렬)",
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "w-full sm:w-auto sm:ml-auto"
          },
          "children": [
            {
              "type": "composite",
              "name": "SearchBar",
              "props": {
                "name": "search",
                "placeholder": "$t:board.search_placeholder",
                "value": "{{query.search || ''}}",
                "showButton": false,
                "className": "w-full sm:w-64"
              },
              "actions": [
                {
                  "type": "submit",
                  "handler": "navigate",
                  "params": {
                    "path": "/board/{{route.slug}}",
                    "mergeQuery": true,
                    "query": {
                      "search": "{{$event.target.search.value}}",
                      "page": 1
                    }
                  }
                }
              ]
            }
          ]
        }
      ]
    },
    {
      "comment": "테이블형 게시글 목록",
      "type": "basic",
      "name": "Div",
      "children": [
        {
          "type": "basic",
          "name": "Div",
          "props": {
            "className": "card bg-base-100 shadow-sm overflow-x-auto"
          },
          "children": [
            {
              "comment": "테이블 헤더 (데스크톱)",
              "type": "basic",
              "name": "Div",
              "props": {
                "className": "hidden lg:grid {{posts?.data?.board?.settings?.show_view_count !== false ? 'grid-cols-[60px_minmax(300px,1fr)_160px_100px_70px]' : 'grid-cols-[60px_minmax(300px,1fr)_160px_100px]'}} gap-4 px-4 py-3 bg-gray-100 dark:bg-gray-700 border-b-2 border-gray-200 dark:border-gray-600 font-medium text-sm text-gray-700 dark:text-gray-300"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Span",
                  "props": { "className": "text-center" },
                  "text": "$t:board.no"
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "text": "$t:board.title"
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "text": "$t:board.author"
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "props": { "className": "text-center" },
                  "text": "$t:board.created_at"
                },
                {
                  "type": "basic",
                  "name": "Span",
                  "if": "{{posts?.data?.board?.settings?.show_view_count !== false}}",
                  "props": { "className": "text-center" },
                  "text": "$t:board.views"
                }
              ]
            },
            {
              "comment": "테이블 바디",
              "type": "basic",
              "name": "Div",
              "iteration": {
                "source": "{{posts?.data?.data ?? []}}",
                "item_var": "post"
              },
              "children": [
                {
                  "type": "basic",
                  "name": "Button",
                  "props": {
                    "className": "{{post?.row_type === 'notice' ? 'bg-blue-50 dark:bg-blue-900/20' : ''}} block w-full text-left hover:bg-gray-50 dark:hover:bg-gray-700/50 transition-colors cursor-pointer border-b border-gray-100 dark:border-gray-700"
                  },
                  "actions": [
                    {
                      "type": "click",
                      "handler": "navigate",
                      "params": { "path": "/board/{{route?.slug}}/{{post?.id}}" }
                    }
                  ],
                  "children": [
                    {
                      "comment": "데스크톱: 테이블 행",
                      "type": "basic",
                      "name": "Div",
                      "props": {
                        "className": "hidden lg:grid {{posts?.data?.board?.settings?.show_view_count !== false ? 'grid-cols-[60px_minmax(300px,1fr)_160px_100px_70px]' : 'grid-cols-[60px_minmax(300px,1fr)_160px_100px]'}} gap-4 px-4 py-3 items-center"
                      },
                      "children": [
                        {
                          "comment": "순번",
                          "type": "basic",
                          "name": "Div",
                          "props": { "className": "flex justify-center" },
                          "children": [
                            {
                              "comment": "공지사항 순번",
                              "type": "basic",
                              "name": "Span",
                              "props": { "className": "inline-flex items-center gap-1 px-2.5 py-0.5 rounded text-xs font-bold bg-blue-600 text-white dark:bg-blue-500" },
                              "if": "{{post?.row_type === 'notice'}}",
                              "children": [
                                { "type": "basic", "name": "Span", "text": "{{post?.number}}" }
                              ]
                            },
                            {
                              "comment": "답글 배지",
                              "type": "basic",
                              "name": "Span",
                              "props": { "className": "inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-purple-100 text-purple-700 dark:bg-purple-900/30 dark:text-purple-300 flex-shrink-0" },
                              "if": "{{post?.row_type === 'reply'}}",
                              "text": "$t:board.post.reply"
                            },
                            {
                              "comment": "일반 게시글 순번",
                              "type": "basic",
                              "name": "Span",
                              "props": { "className": "text-sm text-gray-500 dark:text-gray-400" },
                              "text": "{{post?.number}}",
                              "if": "{{post?.row_type === 'normal'}}"
                            }
                          ]
                        },
                        {
                          "comment": "제목 영역",
                          "type": "basic",
                          "name": "Div",
                          "props": {
                            "className": "flex items-center gap-2 min-w-0",
                            "style": { "marginLeft": "{{Math.min(post?.depth ?? 0, 10) * 1}}rem" }
                          },
                          "children": [
                            {
                              "comment": "답글 화살표 아이콘",
                              "type": "basic",
                              "name": "Icon",
                              "if": "{{post?.row_type === 'reply'}}",
                              "props": { "name": "turn-up", "size": "sm", "className": "fa-rotate-90 text-gray-400 dark:text-gray-500 flex-shrink-0" }
                            },
                            {
                              "comment": "카테고리 배지",
                              "type": "basic",
                              "name": "Span",
                              "if": "{{post?.category}}",
                              "props": { "className": "inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-700 dark:bg-gray-700 dark:text-gray-300 flex-shrink-0" },
                              "text": "{{post?.category}}"
                            },
                            {
                              "comment": "비밀글 아이콘",
                              "type": "basic",
                              "name": "Icon",
                              "if": "{{post?.is_secret}}",
                              "props": { "name": "lock", "size": "sm", "className": "text-gray-500 dark:text-gray-400 flex-shrink-0" }
                            },
                            {
                              "comment": "블라인드 아이콘",
                              "type": "basic",
                              "name": "Icon",
                              "if": "{{post?.status === 'blinded'}}",
                              "props": { "name": "eye-slash", "size": "sm", "className": "text-orange-300 flex-shrink-0" }
                            },
                            {
                              "type": "basic",
                              "name": "Span",
                              "props": {
                                "className": "text-sm font-medium truncate {{(post?.status === 'blinded' || post?.deleted_at) ? 'text-gray-400 dark:text-gray-500' : 'text-gray-700 dark:text-gray-300'}}"
                              },
                              "text": "{{post?.title}}"
                            },
                            {
                              "comment": "첨부파일 아이콘",
                              "type": "basic",
                              "name": "Icon",
                              "if": "{{post?.has_attachment}}",
                              "props": { "name": "paperclip", "size": "sm", "className": "text-gray-500 dark:text-gray-400 flex-shrink-0" }
                            },
                            {
                              "type": "basic",
                              "name": "Span",
                              "if": "{{posts?.data?.board?.settings?.use_comment && post?.comment_count > 0}}",
                              "props": { "className": "text-blue-600 dark:text-blue-400 text-sm font-medium flex-shrink-0" },
                              "text": "[{{post?.comment_count}}]"
                            },
                            {
                              "comment": "삭제됨 배지",
                              "type": "basic",
                              "name": "Span",
                              "if": "{{post?.deleted_at}}",
                              "props": { "className": "inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-300 flex-shrink-0" },
                              "text": "$t:board.post.deleted_badge"
                            },
                            {
                              "type": "basic",
                              "name": "Span",
                              "if": "{{post?.is_new}}",
                              "props": { "className": "px-1.5 py-0.5 text-xs bg-red-500 text-white rounded flex-shrink-0" },
                              "text": "N"
                            }
                          ]
                        },
                        {
                          "comment": "작성자",
                          "type": "basic",
                          "name": "Div",
                          "props": { "className": "flex items-center gap-2" },
                          "children": [
                            {
                              "type": "composite",
                              "name": "Avatar",
                              "props": {
                                "author": "{{post?.author}}",
                                "size": "xs",
                                "className": "{{(post?.status === 'blinded' || post?.deleted_at) ? 'opacity-40' : ''}}"
                              }
                            },
                            {
                              "type": "composite",
                              "name": "UserInfo",
                              "props": {
                                "author": "{{post?.author}}",
                                "showDropdown": true,
                                "stopPropagation": true,
                                "className": "text-sm {{(post?.status === 'blinded' || post?.deleted_at) ? 'text-gray-400 dark:text-gray-500' : 'text-gray-500 dark:text-gray-400'}}"
                              }
                            }
                          ]
                        },
                        {
                          "comment": "작성일",
                          "type": "basic",
                          "name": "Span",
                          "props": { "className": "text-sm text-center whitespace-nowrap {{(post?.status === 'blinded' || post?.deleted_at) ? 'text-gray-400 dark:text-gray-500' : 'text-gray-500 dark:text-gray-400'}}", "title": "{{post?.created_at ?? ''}}" },
                          "text": "{{post?.created_at_formatted ?? ''}}"
                        },
                        {
                          "comment": "조회수",
                          "type": "basic",
                          "name": "Span",
                          "if": "{{posts?.data?.board?.settings?.show_view_count !== false}}",
                          "props": { "className": "text-sm text-center {{(post?.status === 'blinded' || post?.deleted_at) ? 'text-gray-400 dark:text-gray-500' : 'text-gray-500 dark:text-gray-400'}}" },
                          "text": "{{post?.view_count}}"
                        }
                      ]
                    },
                    {
                      "comment": "모바일: 카드 형태",
                      "type": "basic",
                      "name": "Div",
                      "props": { "className": "flex flex-col gap-2 px-4 py-3 lg:hidden" },
                      "children": [
                        {
                          "comment": "상단: 순번 + 제목",
                          "type": "basic",
                          "name": "Div",
                          "props": { "className": "flex items-start gap-2" },
                          "children": [
                            {
                              "comment": "공지 배지",
                              "type": "basic",
                              "name": "Span",
                              "props": { "className": "inline-flex items-center gap-1 px-2 py-0.5 rounded text-xs font-bold bg-blue-600 text-white dark:bg-blue-500 flex-shrink-0" },
                              "if": "{{post?.row_type === 'notice'}}",
                              "children": [
                                { "type": "basic", "name": "Span", "text": "{{post?.number}}" }
                              ]
                            },
                            {
                              "comment": "답글 배지",
                              "type": "basic",
                              "name": "Span",
                              "props": { "className": "inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-purple-100 text-purple-700 dark:bg-purple-900/30 dark:text-purple-300 flex-shrink-0 mt-0.5" },
                              "if": "{{post?.row_type === 'reply'}}",
                              "text": "$t:board.post.reply"
                            },
                            {
                              "comment": "일반 순번",
                              "type": "basic",
                              "name": "Span",
                              "props": { "className": "text-xs text-gray-500 dark:text-gray-400 flex-shrink-0 mt-0.5" },
                              "text": "#{{post?.number}}",
                              "if": "{{post?.row_type === 'normal'}}"
                            },
                            {
                              "comment": "제목 영역",
                              "type": "basic",
                              "name": "Div",
                              "props": {
                                "className": "flex-1 min-w-0",
                                "style": { "marginLeft": "{{Math.min(post?.depth ?? 0, 10) * 1}}rem" }
                              },
                              "children": [
                                {
                                  "type": "basic",
                                  "name": "Div",
                                  "props": { "className": "flex items-center gap-2" },
                                  "children": [
                                    {
                                      "comment": "답글 화살표 아이콘",
                                      "type": "basic",
                                      "name": "Icon",
                                      "if": "{{post?.row_type === 'reply'}}",
                                      "props": { "name": "turn-up", "size": "sm", "className": "fa-rotate-90 text-gray-400 dark:text-gray-500 flex-shrink-0" }
                                    },
                                    {
                                      "comment": "카테고리 배지",
                                      "type": "basic",
                                      "name": "Span",
                                      "if": "{{post?.category}}",
                                      "props": { "className": "inline-flex items-center px-2 py-0.5 rounded text-xs font-medium bg-gray-100 text-gray-700 dark:bg-gray-700 dark:text-gray-300 flex-shrink-0" },
                                      "text": "{{post?.category}}"
                                    },
                                    {
                                      "comment": "비밀글 아이콘",
                                      "type": "basic",
                                      "name": "Icon",
                                      "if": "{{post?.is_secret}}",
                                      "props": { "name": "lock", "size": "sm", "className": "text-gray-500 dark:text-gray-400 flex-shrink-0" }
                                    },
                                    {
                                      "comment": "블라인드 아이콘",
                                      "type": "basic",
                                      "name": "Icon",
                                      "if": "{{post?.status === 'blinded'}}",
                                      "props": { "name": "eye-slash", "size": "sm", "className": "text-orange-300 flex-shrink-0" }
                                    },
                                    {
                                      "type": "basic",
                                      "name": "Span",
                                      "props": {
                                        "className": "text-sm font-medium {{(post?.status === 'blinded' || post?.deleted_at) ? 'text-gray-400 dark:text-gray-500' : 'text-gray-700 dark:text-gray-300'}}"
                                      },
                                      "text": "{{post?.title}}"
                                    },
                                    {
                                      "comment": "첨부파일 아이콘",
                                      "type": "basic",
                                      "name": "Icon",
                                      "if": "{{post?.has_attachment}}",
                                      "props": { "name": "paperclip", "size": "sm", "className": "text-gray-500 dark:text-gray-400 flex-shrink-0" }
                                    },
                                    {
                                      "type": "basic",
                                      "name": "Span",
                                      "if": "{{posts?.data?.board?.settings?.use_comment && post?.comment_count > 0}}",
                                      "props": { "className": "text-blue-600 dark:text-blue-400 text-sm font-medium flex-shrink-0" },
                                      "text": "[{{post?.comment_count}}]"
                                    },
                                    {
                                      "comment": "삭제됨 배지",
                                      "type": "basic",
                                      "name": "Span",
                                      "if": "{{post?.deleted_at}}",
                                      "props": { "className": "inline-flex items-center px-1.5 py-0.5 rounded text-xs font-medium bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-300 flex-shrink-0" },
                                      "text": "$t:board.post.deleted_badge"
                                    },
                                    {
                                      "type": "basic",
                                      "name": "Span",
                                      "if": "{{post?.is_new}}",
                                      "props": { "className": "px-1.5 py-0.5 text-xs bg-red-500 text-white rounded flex-shrink-0" },
                                      "text": "N"
                                    }
                                  ]
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "comment": "하단: 작성자, 작성일, 조회수",
                          "type": "basic",
                          "name": "Div",
                          "props": { "className": "flex items-center justify-between text-xs {{(post?.status === 'blinded' || post?.deleted_at) ? 'text-gray-400 dark:text-gray-500' : 'text-gray-500 dark:text-gray-400'}}" },
                          "children": [
                            {
                              "type": "basic",
                              "name": "Div",
                              "props": { "className": "flex items-center gap-2" },
                              "children": [
                                {
                                  "type": "composite",
                                  "name": "Avatar",
                                  "props": {
                                    "author": "{{post?.author}}",
                                    "size": "xs",
                                    "className": "{{(post?.status === 'blinded' || post?.deleted_at) ? 'opacity-40' : ''}}"
                                  }
                                },
                                {
                                  "type": "composite",
                                  "name": "UserInfo",
                                  "props": {
                                    "author": "{{post?.author}}",
                                    "showDropdown": true,
                                    "stopPropagation": true,
                                    "className": "text-xs {{(post?.status === 'blinded' || post?.deleted_at) ? 'text-gray-400 dark:text-gray-500' : 'text-gray-500 dark:text-gray-400'}}"
                                  }
                                }
                              ]
                            },
                            {
                              "type": "basic",
                              "name": "Div",
                              "props": { "className": "flex items-center gap-3" },
                              "children": [
                                {
                                  "type": "basic",
                                  "name": "Span",
                                  "props": { "title": "{{post?.created_at ?? ''}}" },
                                  "text": "{{post?.created_at_formatted ?? ''}}"
                                },
                                {
                                  "type": "basic",
                                  "name": "Span",
                                  "if": "{{posts?.data?.board?.settings?.show_view_count !== false}}",
                                  "text": "$t:board.views_count|count={{post?.view_count}}"
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    }
                  ]
                }
              ]
            }
          ]
        }
      ]
