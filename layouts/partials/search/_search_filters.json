{
  "meta": { "is_partial": true, "description": "검색 필터 (게시글/상품 탭)" },
  "type": "basic",
  "name": "Div",
  "if": "{{(_global?.searchActiveTab === 'posts' || _global?.searchActiveTab === 'products') && query?.q}}",
  "props": { "className": "flex flex-wrap gap-2 mb-4" },
  "children": [
    {
      "type": "basic",
      "name": "Select",
      "if": "{{_global?.searchActiveTab === 'posts'}}",
      "props": {
        "name": "boardFilter",
        "className": "w-40 px-4 py-2.5 bg-gray-100 dark:bg-gray-700 border-0 rounded-xl text-gray-700 dark:text-gray-200 font-medium focus:ring-2 focus:ring-blue-500 focus:outline-none cursor-pointer",
        "value": "{{_global?.searchBoardFilter ?? ''}}"
      },
      "children": [
        { "type": "basic", "name": "Option", "props": { "value": "" }, "text": "$t:search.filter.all_boards" },
        {
          "type": "basic",
          "name": "Option",
          "iteration": { "source": "{{searchResults?.data?.posts?.available_boards ?? []}}", "item_var": "board" },
          "props": { "value": "{{board?.slug}}" },
          "text": "{{board?.name}}"
        }
      ],
      "actions": [
        {
          "type": "change",
          "handler": "sequence",
          "actions": [
            { "handler": "setState", "params": { "target": "global", "searchBoardFilter": "{{$event.target.value}}", "searchPage": 1 } },
            { "handler": "refetchDataSource", "params": { "dataSourceId": "searchResults" } }
          ]
        }
      ]
    },
    {
      "type": "composite",
      "name": "Select",
      "if": "{{_global?.searchActiveTab === 'posts'}}",
      "props": {
        "name": "sortBy",
        "className": "w-32",
        "value": "{{_global?.searchSortBy ?? 'relevance'}}",
        "options": [
          { "value": "relevance", "label": "$t:search.sort.relevance" },
          { "value": "latest", "label": "$t:search.sort.latest" },
          { "value": "popular", "label": "$t:search.sort.popular" }
        ]
      },
      "actions": [
        {
          "type": "change",
          "handler": "sequence",
          "actions": [
            { "handler": "setState", "params": { "target": "global", "searchSortBy": "{{$event.target.value}}", "searchPage": 1 } },
            { "handler": "refetchDataSource", "params": { "dataSourceId": "searchResults" } }
          ]
        }
      ]
    },
    {
      "type": "composite",
      "name": "Select",
      "if": "{{_global?.searchActiveTab === 'products'}}",
      "props": {
        "name": "sortBy",
        "className": "w-32",
        "value": "{{_global?.searchSortBy ?? 'relevance'}}",
        "options": [
          { "value": "relevance", "label": "$t:search.sort.relevance" },
          { "value": "latest", "label": "$t:search.sort.latest" },
          { "value": "price_asc", "label": "$t:search.sort.price_asc" },
          { "value": "price_desc", "label": "$t:search.sort.price_desc" },
          { "value": "popular", "label": "$t:search.sort.popular" }
        ]
      },
      "actions": [
        {
          "type": "change",
          "handler": "sequence",
          "actions": [
            { "handler": "setState", "params": { "target": "global", "searchSortBy": "{{$event.target.value}}", "searchPage": 1 } },
            { "handler": "refetchDataSource", "params": { "dataSourceId": "searchResults" } }
          ]
        }
      ]
    }
  ]
}