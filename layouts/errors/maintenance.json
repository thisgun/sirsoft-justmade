{
  "version": "1.0.0",
  "layout_name": "maintenance",
  "extends": "_user_base",
  "meta": {
    "title": "$t:error.maintenance.title",
    "description": "$t:error.maintenance.description",
    "is_error_layout": true
  },
  "slots": {
    "content": [
      {
        "type": "basic",
        "name": "Div",
        "props": {
          "className": "min-h-[60vh] flex items-center justify-center"
        },
        "children": [
          {
            "type": "basic",
            "name": "Div",
            "props": {
              "className": "text-center px-4 max-w-lg"
            },
            "children": [
              {
                "type": "basic",
                "name": "Icon",
                "props": {
                  "name": "gear",
                  "className": "w-24 h-24 mx-auto text-primary mb-6 animate-spin"
                }
              },
              {
                "type": "basic",
                "name": "H1",
                "props": {
                  "className": "text-2xl font-bold text-base-content mb-4"
                },
                "text": "$t:error.maintenance.title"
              },
              {
                "type": "basic",
                "name": "P",
                "props": {
                  "className": "text-base-content/60 mb-8"
                },
                "text": "$t:error.maintenance.description"
              },
              {
                "type": "basic",
                "name": "Button",
                "props": {
                  "className": "btn btn-primary gap-2 cursor-pointer"
                },
                "actions": [{ "type": "click", "handler": "navigate", "params": { "path": "/" } }],
                "children": [
                  {
                    "type": "basic",
                    "name": "Icon",
                    "props": {
                      "name": "home",
                      "className": "w-5 h-5"
                    }
                  },
                  {
                    "type": "basic",
                    "name": "Span",
                    "text": "$t:error.maintenance.back_to_home"
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
