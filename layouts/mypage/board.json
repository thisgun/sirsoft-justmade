{
  "version": "1.0.0",
  "layout_name": "mypage/board",
  "extends": "_user_base",
  "permissions": [],
  "transition_overlay": {
    "enabled": true,
    "style": "spinner",
    "target": "mypage_tab_content",
    "fallback_target": "main_content_area",
    "spinner": {
      "component": "PageLoading"
    }
  },
  "computed": {
    "currentTab": "board"
  },
  "global_state": {
    "boardActivitySubTab": "my-posts",
    "myPostsPage": 1,
    "myPostsBoard": "",
    "myPostsSearch": "",
    "myPostsSort": "latest",
    "myCommentsPage": 1,
    "myCommentsBoard": "",
    "myCommentsSearch": "",
    "myCommentsSort": "latest"
  },
  "data_sources": [
    {
      "id": "myActivityStats",
      "type": "api",
      "endpoint": "/api/modules/sirsoft-board/me/activity-stats",
      "method": "GET",
      "auto_fetch": true,
      "auth_required": true
    },
    {
      "id": "myPosts",
      "type": "api",
      "endpoint": "/api/modules/sirsoft-board/me/board-activities?page={{_global.myPostsPage ?? 1}}&board_slug={{_global.myPostsBoard ?? ''}}&search={{_global.myPostsSearch ?? ''}}&sort={{_global.myPostsSort ?? 'latest'}}&activity_type=authored&per_page=10",
      "method": "GET",
      "auto_fetch": true,
      "auth_required": true,
      "loading_strategy": "progressive",
      "lazy": true,
      "blur_until_loaded": true
    },
    {
      "id": "myComments",
      "type": "api",
      "endpoint": "/api/modules/sirsoft-board/me/my-comments?page={{_global.myCommentsPage ?? 1}}&board_slug={{_global.myCommentsBoard ?? ''}}&search={{_global.myCommentsSearch ?? ''}}&sort={{_global.myCommentsSort ?? 'latest'}}&per_page=10",
      "method": "GET",
      "auto_fetch": false,
      "auth_required": true,
      "loading_strategy": "progressive",
      "lazy": true,
      "blur_until_loaded": true
    }
  ],
  "slots": {
    "content": [
      {
        "comment": "breadcrumb navigation",
        "type": "basic",
        "name": "Nav",
        "props": {
          "className": "bc-nav",
          "aria-label": "Breadcrumb"
        },
        "children": [
          {
            "type": "basic",
            "name": "Button",
            "props": {
              "className": "bc-link"
            },
            "actions": [
              {
                "type": "click",
                "handler": "navigate",
                "params": {
                  "path": "/"
                }
              }
            ],
            "text": "$t:nav.home"
          },
          {
            "type": "basic",
            "name": "Span",
            "props": {
              "className": "bc-sep"
            },
            "text": "/"
          },
          {
            "type": "basic",
            "name": "Span",
            "props": {
              "className": "bc-current"
            },
            "text": "$t:nav.mypage"
          }
        ]
      },
      {
        "type": "basic",
        "name": "Div",
        "props": {
          "className": "min-h-screen bg-gray-50 dark:bg-gray-900"
        },
        "children": [
          {
            "type": "layout",
            "name": "Container",
            "props": {
              "className": "py-8"
            },
            "responsive": {
              "portable": {
                "props": {
                  "className": "py-4"
                }
              }
            },
            "children": [
              {
                "comment": "페이지 제목",
                "type": "basic",
                "name": "Div",
                "props": {
                  "className": "flex items-center gap-2 mb-6"
                },
                "children": [
                  {
                    "type": "basic",
                    "name": "Icon",
                    "props": {
                      "name": "user",
                      "size": "xl",
                      "className": "text-gray-900 dark:text-white"
                    }
                  },
                  {
                    "type": "basic",
                    "name": "H1",
                    "props": {
                      "className": "text-2xl font-bold text-gray-900 dark:text-white"
                    },
                    "text": "$t:mypage.title"
                  }
                ]
              },
              {
                "comment": "탭 네비게이션",
                "partial": "partials/mypage/_tab_navigation.json"
              },
              {
                "comment": "탭 컨텐츠 영역 (스켈레톤 타겟)",
                "type": "basic",
                "name": "Div",
                "id": "mypage_tab_content",
                "children": [
                  {
                    "comment": "게시판 활동",
                    "partial": "partials/mypage/board/_list.json"
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}