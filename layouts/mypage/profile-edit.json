{
  "version": "1.0.0",
  "layout_name": "mypage/profile-edit",
  "extends": "_user_base",
  "permissions": [],
  "data_sources": [
    {
      "id": "user",
      "type": "api",
      "endpoint": "/api/me",
      "method": "GET",
      "auto_fetch": true,
      "auth_required": true,
      "loading_strategy": "progressive",
      "initLocal": "profileEditForm",
      "blur_until_loaded": true,
      "refetchOnMount": true
    }
  ],
  "init_actions": [
    {
      "handler": "setState",
      "params": {
        "target": "local",
        "isPasswordVerified": false,
        "verifyPassword": "",
        "isVerifyingPassword": false,
        "verifyPasswordError": false
      }
    }
  ],
  "defines": {
    "countryList": [
        { "code": "KR", "name": "countries.KR" },
        { "code": "US", "name": "countries.US" },
        { "code": "JP", "name": "countries.JP" },
        { "code": "CN", "name": "countries.CN" },
        { "code": "GB", "name": "countries.GB" },
        { "code": "DE", "name": "countries.DE" },
        { "code": "FR", "name": "countries.FR" },
        { "code": "CA", "name": "countries.CA" },
        { "code": "AU", "name": "countries.AU" },
        { "code": "IN", "name": "countries.IN" },
        { "code": "BR", "name": "countries.BR" },
        { "code": "RU", "name": "countries.RU" },
        { "code": "IT", "name": "countries.IT" },
        { "code": "ES", "name": "countries.ES" },
        { "code": "MX", "name": "countries.MX" },
        { "code": "NL", "name": "countries.NL" },
        { "code": "SE", "name": "countries.SE" },
        { "code": "CH", "name": "countries.CH" },
        { "code": "SG", "name": "countries.SG" },
        { "code": "HK", "name": "countries.HK" },
        { "code": "TW", "name": "countries.TW" },
        { "code": "TH", "name": "countries.TH" },
        { "code": "VN", "name": "countries.VN" },
        { "code": "PH", "name": "countries.PH" },
        { "code": "MY", "name": "countries.MY" },
        { "code": "ID", "name": "countries.ID" },
        { "code": "NZ", "name": "countries.NZ" },
        { "code": "AT", "name": "countries.AT" },
        { "code": "BE", "name": "countries.BE" },
        { "code": "DK", "name": "countries.DK" },
        { "code": "FI", "name": "countries.FI" },
        { "code": "NO", "name": "countries.NO" },
        { "code": "PL", "name": "countries.PL" },
        { "code": "PT", "name": "countries.PT" },
        { "code": "IE", "name": "countries.IE" },
        { "code": "GR", "name": "countries.GR" },
        { "code": "CZ", "name": "countries.CZ" },
        { "code": "HU", "name": "countries.HU" },
        { "code": "TR", "name": "countries.TR" },
        { "code": "IL", "name": "countries.IL" },
        { "code": "AE", "name": "countries.AE" },
        { "code": "SA", "name": "countries.SA" },
        { "code": "ZA", "name": "countries.ZA" },
        { "code": "EG", "name": "countries.EG" },
        { "code": "AR", "name": "countries.AR" },
        { "code": "CL", "name": "countries.CL" },
        { "code": "CO", "name": "countries.CO" },
        { "code": "PE", "name": "countries.PE" }
    ],
    "languageList": [
        { "code": "ko", "name": "languages.ko" },
        { "code": "en", "name": "languages.en" }
    ]
  },
  "slots": {
    "content": [
      {
        "comment": "breadcrumb navigation",
        "type": "basic",
        "name": "Nav",
        "props": {
          "className": "bc-nav",
          "aria-label": "Breadcrumb"
        },
        "children": [
          {
            "type": "basic",
            "name": "Button",
            "props": {
              "className": "bc-link"
            },
            "actions": [
              {
                "type": "click",
                "handler": "navigate",
                "params": {
                  "path": "/"
                }
              }
            ],
            "text": "$t:nav.home"
          },
          {
            "type": "basic",
            "name": "Span",
            "props": {
              "className": "bc-sep"
            },
            "text": "/"
          },
          {
            "type": "basic",
            "name": "Button",
            "props": {
              "className": "bc-link"
            },
            "actions": [
              {
                "type": "click",
                "handler": "navigate",
                "params": {
                  "path": "/mypage/profile"
                }
              }
            ],
            "text": "$t:nav.mypage"
          },
          {
            "type": "basic",
            "name": "Span",
            "props": {
              "className": "bc-sep"
            },
            "text": "/"
          },
          {
            "type": "basic",
            "name": "Span",
            "props": {
              "className": "bc-current"
            },
            "text": "$t:nav.profile_edit"
          }
        ]
      },
      {
        "type": "basic",
        "name": "Div",
        "props": {
          "className": "min-h-screen bg-gray-50 dark:bg-gray-900"
        },
        "children": [
          {
            "type": "layout",
            "name": "Container",
            "props": {
              "className": "py-8"
            },
            "responsive": {
              "portable": {
                "props": {
                  "className": "py-4"
                }
              }
            },
            "children": [
              {
                "comment": "페이지 제목",
                "type": "basic",
                "name": "Div",
                "props": {
                  "className": "flex items-center gap-2 mb-6"
                },
                "children": [
                  {
                    "type": "basic",
                    "name": "Icon",
                    "props": {
                      "name": "pen-to-square",
                      "size": "xl",
                      "className": "text-gray-900 dark:text-white"
                    }
                  },
                  {
                    "type": "basic",
                    "name": "H1",
                    "props": {
                      "className": "text-2xl font-bold text-gray-900 dark:text-white"
                    },
                    "text": "$t:mypage.profile_edit_title"
                  }
                ]
              },
              {
                "comment": "비밀번호 검증 섹션",
                "partial": "partials/mypage/profile/_password_verify_section.json"
              },
              {
                "comment": "프로필 편집 폼",
                "partial": "partials/mypage/profile/_edit.json"
              }
            ]
          }
        ]
      }
    ]
  }
}