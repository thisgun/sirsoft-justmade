{
  "version": "1.0.0",
  "layout_name": "mypage/orders",
  "extends": "_user_base",
  "permissions": [],
  "transition_overlay": {
    "enabled": true,
    "style": "spinner",
    "target": "mypage_tab_content",
    "fallback_target": "main_content_area",
    "spinner": {
      "component": "PageLoading"
    }
  },
  "computed": {
    "currentTab": "orders"
  },
  "data_sources": [
    {
      "id": "orders",
      "type": "api",
      "endpoint": "/api/modules/sirsoft-ecommerce/user/orders",
      "method": "GET",
      "auto_fetch": true,
      "auth_required": true,
      "loading_strategy": "progressive",
      "blur_until_loaded": true,
      "params": {
        "page": "{{query.page ?? 1}}",
        "status": "{{query.status}}"
      }
    }
  ],
  "init_actions": [
    {
      "handler": "setState",
      "params": {
        "target": "local",
        "ordersPage": "{{query.page ?? 1}}",
        "ordersStatus": "{{query.status ?? ''}}"
      }
    }
  ],
  "slots": {
    "content": [
      {
        "comment": "breadcrumb navigation",
        "type": "basic",
        "name": "Nav",
        "props": {
          "className": "bc-nav",
          "aria-label": "Breadcrumb"
        },
        "children": [
          {
            "type": "basic",
            "name": "Button",
            "props": {
              "className": "bc-link"
            },
            "actions": [
              {
                "type": "click",
                "handler": "navigate",
                "params": {
                  "path": "/"
                }
              }
            ],
            "text": "$t:nav.home"
          },
          {
            "type": "basic",
            "name": "Span",
            "props": {
              "className": "bc-sep"
            },
            "text": "/"
          },
          {
            "type": "basic",
            "name": "Button",
            "props": {
              "className": "bc-link"
            },
            "actions": [
              {
                "type": "click",
                "handler": "navigate",
                "params": {
                  "path": "/mypage/profile"
                }
              }
            ],
            "text": "$t:nav.mypage"
          },
          {
            "type": "basic",
            "name": "Span",
            "props": {
              "className": "bc-sep"
            },
            "text": "/"
          },
          {
            "type": "basic",
            "name": "Span",
            "props": {
              "className": "bc-current"
            },
            "text": "$t:nav.orders"
          }
        ]
      },
      {
        "type": "basic",
        "name": "Div",
        "props": {
          "className": "min-h-screen bg-gray-50 dark:bg-gray-900"
        },
        "children": [
          {
            "type": "layout",
            "name": "Container",
            "props": {
              "className": "py-8"
            },
            "responsive": {
              "portable": {
                "props": {
                  "className": "py-4"
                }
              }
            },
            "children": [
              {
                "comment": "페이지 제목",
                "type": "basic",
                "name": "Div",
                "props": {
                  "className": "flex items-center gap-2 mb-6"
                },
                "children": [
                  {
                    "type": "basic",
                    "name": "Icon",
                    "props": {
                      "name": "user",
                      "size": "xl",
                      "className": "text-gray-900 dark:text-white"
                    }
                  },
                  {
                    "type": "basic",
                    "name": "H1",
                    "props": {
                      "className": "text-2xl font-bold text-gray-900 dark:text-white"
                    },
                    "text": "$t:mypage.title"
                  }
                ]
              },
              {
                "comment": "탭 네비게이션",
                "partial": "partials/mypage/_tab_navigation.json"
              },
              {
                "comment": "탭 컨텐츠 영역 (스켈레톤 타겟)",
                "type": "basic",
                "name": "Div",
                "id": "mypage_tab_content",
                "children": [
                  {
                    "comment": "주문내역",
                    "partial": "partials/mypage/orders/_list.json"
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}