{
  "version": "1.0.0",
  "layout_name": "auth/forgot_password",
  "extends": "_user_base",
  "meta": {
    "title": "$t:auth.forgot_password.title",
    "guest_only": true
  },
  "slots": {
    "content": [
      {
        "type": "basic",
        "name": "Div",
        "blur_until_loaded": "{{_global?.currentUser?.uuid}}",
        "props": {
          "className": "min-h-[60vh] flex items-center justify-center py-12 px-4"
        },
        "children": [
          {
            "partial": "partials/auth/_redirect_if_logged_in.json"
          },
          {
            "comment": "비밀번호 찾기 폼",
            "type": "basic",
            "name": "Div",
            "props": {
              "className": "w-full max-w-md"
            },
            "children": [
              {
                "type": "basic",
                "name": "Div",
                "props": {
                  "className": "card bg-base-100 shadow-sm p-8"
                },
                "responsive": {
                  "portable": {
                    "props": {
                      "className": "card bg-base-100 shadow-sm p-6"
                    }
                  }
                },
                "children": [
                  {
                    "comment": "헤더",
                    "type": "basic",
                    "name": "Div",
                    "props": {
                      "className": "text-center mb-8"
                    },
                    "children": [
                      {
                        "type": "basic",
                        "name": "H1",
                        "props": {
                          "className": "text-2xl font-bold text-gray-900 dark:text-white mb-2"
                        },
                        "text": "$t:auth.forgot_password.title"
                      },
                      {
                        "type": "basic",
                        "name": "P",
                        "props": {
                          "className": "text-gray-600 dark:text-gray-400"
                        },
                        "text": "$t:auth.forgot_password.subtitle"
                      }
                    ]
                  },
                  {
                    "comment": "성공 메시지",
                    "type": "basic",
                    "name": "Div",
                    "props": {
                      "className": "mb-6 p-4 bg-green-50 dark:bg-green-900/30 border border-green-200 dark:border-green-800 rounded-lg"
                    },
                    "if": "{{_local.success}}",
                    "children": [
                      {
                        "type": "basic",
                        "name": "P",
                        "props": {
                          "className": "text-green-700 dark:text-green-300 text-sm"
                        },
                        "text": "$t:auth.forgot_password.success"
                      }
                    ]
                  },
                  {
                    "comment": "폼",
                    "type": "basic",
                    "name": "Form",
                    "props": {
                      "className": "space-y-6"
                    },
                    "if": "{{!_local.success}}",
                    "actions": [
                      {
                        "type": "submit",
                        "handler": "sequence",
                        "actions": [
                          {
                            "handler": "setState",
                            "params": {
                              "target": "local",
                              "isSubmitting": true
                            }
                          },
                          {
                            "handler": "apiCall",
                            "target": "/api/auth/forgot-password",
                            "params": {
                              "method": "POST",
                              "body": {
                                "email": "{{form.email}}"
                              }
                            },
                            "onSuccess": {
                              "handler": "setState",
                              "params": {
                                "target": "local",
                                "isSubmitting": false,
                                "success": true
                              }
                            },
                            "onError": [
                              {
                                "handler": "setState",
                                "params": {
                                  "target": "local",
                                  "isSubmitting": false
                                }
                              },
                              {
                                "handler": "toast",
                                "params": {
                                  "type": "error",
                                  "message": "{{error.message}}"
                                }
                              }
                            ]
                          }
                        ]
                      }
                    ],
                    "children": [
                      {
                        "comment": "이메일 입력",
                        "type": "basic",
                        "name": "Div",
                        "children": [
                          {
                            "type": "basic",
                            "name": "Label",
                            "props": {
                              "className": "block text-sm font-medium text-gray-700 dark:text-gray-300 mb-2"
                            },
                            "text": "$t:auth.forgot_password.email"
                          },
                          {
                            "type": "basic",
                            "name": "Input",
                            "props": {
                              "type": "email",
                              "name": "email",
                              "placeholder": "$t:auth.forgot_password.email_placeholder",
                              "className": "input input-bordered w-full disabled:opacity-50 disabled:cursor-not-allowed",
                              "required": true,
                              "disabled": "{{_local.isSubmitting ?? false}}"
                            }
                          }
                        ]
                      },
                      {
                        "comment": "제출 버튼",
                        "type": "basic",
                        "name": "Button",
                        "props": {
                          "type": "submit",
                          "className": "btn btn-primary w-full disabled:opacity-50 disabled:cursor-not-allowed flex items-center justify-center gap-2",
                          "disabled": "{{_local.isSubmitting ?? false}}"
                        },
                        "children": [
                          {
                            "comment": "스피너",
                            "type": "basic",
                            "name": "Div",
                            "if": "{{_local.isSubmitting}}",
                            "props": {
                              "className": "w-5 h-5 border-2 border-white/30 border-t-white rounded-full animate-spin"
                            }
                          },
                          {
                            "type": "basic",
                            "name": "Span",
                            "if": "{{!_local.isSubmitting}}",
                            "text": "$t:auth.forgot_password.submit"
                          },
                          {
                            "type": "basic",
                            "name": "Span",
                            "if": "{{_local.isSubmitting}}",
                            "text": "$t:auth.forgot_password.processing"
                          }
                        ]
                      }
                    ]
                  },
                  {
                    "comment": "로그인 링크",
                    "type": "basic",
                    "name": "Div",
                    "props": {
                      "className": "mt-6 text-center"
                    },
                    "children": [
                      {
                        "type": "basic",
                        "name": "Button",
                        "props": {
                          "className": "link link-primary text-sm cursor-pointer"
                        },
                        "actions": [
                          {
                            "type": "click",
                            "handler": "navigate",
                            "params": {
                              "path": "/login"
                            }
                          }
                        ],
                        "text": "$t:auth.forgot_password.back_to_login"
                      }
                    ]
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}